---
interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

import { sitePath } from '../lib/paths';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const publicSiteUrl = `${siteUrl}${sitePath('/')}`.replace(/\/$/, '');

const {
  title,
  description,
  ogTitle = 'Forager',
  ogDescription = 'Local meta-harness for harness-backed AI agents. Approvals, evidence, recovery, reviewable handoffs, and continuity.',
  ogImage = `${publicSiteUrl}/assets/social-preview.png`
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Forager",
  "description": "Local meta-harness for Linux and macOS using tmux to supervise harness-backed AI agent work with approvals, durable evidence, recovery, and reviewable handoffs.",
  "url": publicSiteUrl,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux, macOS",
  "programmingLanguage": "Rust",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "Forager Contributors",
    "url": "https://github.com/kimyoungjin06/forager-cli"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Korea Institute of Science and Technology Information",
    "alternateName": "KISTI",
    "url": "https://www.kisti.re.kr/",
    "logo": `${publicSiteUrl}/assets/kisti-logo-en.png`
  },
  "license": "https://github.com/kimyoungjin06/forager-cli/blob/main/LICENSE",
  "codeRepository": "https://github.com/kimyoungjin06/forager-cli",
  "keywords": ["AI coding agent", "local meta-harness", "harness-backed agents", "offdesk autonomy", "terminal session manager", "tmux", "Claude Code", "Codex", "OpenCode", "OpenHands", "Mistral Vibe", "Gemini CLI", "git worktrees"]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="AI coding agent, local meta-harness, harness-backed agents, offdesk autonomy, terminal session manager, tmux, Claude Code, Codex, OpenCode, OpenHands, Mistral Vibe, Gemini CLI, git worktrees, Rust, TUI, CLI, developer tools">
  <meta name="author" content="Forager Contributors">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalURL}>

  <!-- Open Graph -->
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Forager">
  <meta property="og:locale" content="en_US">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={ogTitle}>
  <meta name="twitter:description" content={ogDescription}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={sitePath('/assets/logo.svg')}>
  <link rel="icon" type="image/png" href={sitePath('/assets/logo.png')}>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" as="style">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href={sitePath('/styles.css')}>
</head>
<body class="gradient-bg min-h-screen text-gray-100 antialiased">
  <slot />
  <script is:inline src={sitePath('/main.js')}></script>
</body>
</html>
