---

<div class="max-w-2xl mx-auto mb-8">
  <div class="code-block rounded-lg p-1">
    <div class="flex items-center gap-2 px-4 py-2 border-b border-surface-700/50">
      <div class="w-3 h-3 rounded-full bg-kisti-red/80"></div>
      <div class="w-3 h-3 rounded-full bg-kisti-cyan/80"></div>
      <div class="w-3 h-3 rounded-full bg-kisti-blue/80"></div>
      <span class="ml-2 text-xs text-gray-500 font-mono">Terminal</span>
    </div>
    <div class="px-5 py-4 font-mono text-sm sm:text-base md:text-lg flex items-start justify-between gap-4">
      <code class="min-w-0 flex-1 text-left text-gray-300 leading-relaxed">
        <span class="text-gray-500 select-none">$ </span><span class="text-brand-400">curl</span> -fsSL \<br>
        <span class="inline-block pl-4">https://kimyoungjin06.github.io/<br class="sm:hidden">forager-cli/install.sh \</span><br>
        <span class="inline-block pl-4"><span class="text-gray-500">|</span> <span class="text-brand-400">bash</span></span>
      </code>
      <button onclick="copyInstall()" id="copy-btn" class="text-gray-500 hover:text-brand-400 transition-colors p-2 rounded-md hover:bg-surface-700/50 flex-shrink-0" title="Copy to clipboard">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </button>
    </div>
  </div>
</div>
