---
import { sitePath } from '../lib/paths';
---

<footer class="py-12 px-6 border-t border-surface-800/50">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <img src={sitePath('/assets/logo.svg')} alt="Forager" class="w-6 h-6">
      <span class="text-gray-500">Forager</span>
    </div>

    <div class="flex items-center flex-wrap justify-center gap-x-8 gap-y-2 text-gray-400 text-sm">
      <a href={sitePath('/docs/')} class="hover:text-white transition-colors">Documentation</a>
      <a href="https://github.com/kimyoungjin06/forager-cli" class="hover:text-white transition-colors">GitHub</a>
      <a href="https://github.com/kimyoungjin06/forager-cli/releases" class="hover:text-white transition-colors">Releases</a>
      <a href="https://github.com/kimyoungjin06/forager-cli/blob/main/LICENSE" class="hover:text-white transition-colors">MIT License</a>
    </div>
  </div>
</footer>
