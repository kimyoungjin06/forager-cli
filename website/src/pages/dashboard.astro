---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sitePath } from '../lib/paths';
import {
  dashboardViewFromSurface,
  formatLabel,
  severityClasses,
  severityLabels,
  statusClasses,
  type DashboardView,
} from '../lib/dashboardSurface';

import workstationSurface from '../../../tests/fixtures/ui/workstation_surface/attention.json';

const dashboardView = dashboardViewFromSurface(workstationSurface) as DashboardView;
const selectedProjectDetail = dashboardView.projectDetails[0];
const selectedGraphTitle = selectedProjectDetail?.graph_title ?? dashboardView.graphTitle;
const selectedGraphEdges = selectedProjectDetail?.graph_edges.length
  ? selectedProjectDetail.graph_edges
  : dashboardView.graphEdges;
---

<Base
  title="Forager Dashboard"
  description="Read-only Forager workstation dashboard for projects, decisions, health, provenance, and accepted-truth state."
>
  <Nav />

  <main
    id="dashboard-app"
    class="min-h-screen bg-[#08111d] pt-24 text-slate-100"
    data-live-surface-url={sitePath('/workstation-surface.json')}
  >
    <section class="border-y border-slate-700/70 bg-[#101a27] px-6 py-5">
      <div class="mx-auto grid max-w-7xl gap-5 xl:grid-cols-[1fr_auto] xl:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-300">Forager Operations</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">Workstation command center</h1>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-400">
            Source: <span class="font-medium text-slate-200" data-dashboard-source>{dashboardView.sourceLabel}</span>
            <span class="text-slate-600"> / </span>
            Profile: <span class="font-mono text-slate-200" data-dashboard-profile>{dashboardView.profile}</span>
            <span class="text-slate-600"> / </span>
            Freshness: <span class="font-medium text-slate-200" data-dashboard-stale>{dashboardView.staleLabel}</span>
          </p>
        </div>

        <div class="grid gap-3 text-sm sm:grid-cols-3">
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Workstation</p>
            <p class="mt-1 font-mono text-slate-100" data-dashboard-workstation>{dashboardView.workstationId}</p>
          </div>
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Generated</p>
            <p class="mt-1 font-mono text-slate-100" data-dashboard-generated>{dashboardView.generatedAt}</p>
          </div>
          <div
            class={`border px-4 py-3 ${severityClasses[dashboardView.topSeverity]}`}
            data-dashboard-top-severity
            data-base-class="border px-4 py-3"
          >
            <p class="opacity-75">Top attention</p>
            <p class="mt-1 font-semibold" data-dashboard-top-severity-label>{severityLabels[dashboardView.topSeverity]}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-7xl gap-6 px-6 py-8 xl:grid-cols-[1.25fr_0.75fr]">
      <section class="min-w-0 space-y-6">
        <div
          class={`min-w-0 border p-6 ${severityClasses[dashboardView.topSeverity]}`}
          data-dashboard-top-card
          data-base-class="min-w-0 border p-6"
        >
          <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-start">
            <div class="min-w-0">
              <p class="text-sm font-semibold uppercase tracking-[0.14em] opacity-75">Now</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white" data-dashboard-top-title>{dashboardView.topTitle}</h2>
              <p class="mt-4 max-w-4xl text-base leading-relaxed text-slate-100" data-dashboard-top-summary>{dashboardView.topSummary}</p>
            </div>
            <div class="flex flex-wrap gap-3">
              <a
                href={sitePath('/decisions/')}
                class="inline-flex border border-white/20 bg-slate-950/35 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-950/55"
                data-dashboard-top-action
              >
                {dashboardView.topAction}
              </a>
              <a
                href={sitePath('/review/')}
                class="inline-flex border border-slate-500/60 bg-slate-900/70 px-4 py-2 text-sm font-semibold text-slate-100 hover:bg-slate-800"
              >
                Open review
              </a>
            </div>
          </div>
        </div>

        <section class="grid min-w-0 gap-4 md:grid-cols-2 xl:grid-cols-3" data-dashboard-attention-counts>
          {dashboardView.attentionCounts.length ? (
            dashboardView.attentionCounts.map((item) => (
              <div class="min-w-0 border border-slate-700 bg-slate-900/70 p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">{formatLabel(item.label)}</p>
                <p class="mt-3 font-mono text-3xl text-white">{item.value}</p>
              </div>
            ))
          ) : (
            <div class="min-w-0 border border-emerald-400/35 bg-emerald-400/10 p-5 text-emerald-100 md:col-span-2 xl:col-span-3">
              <p class="text-xs font-semibold uppercase tracking-[0.14em] opacity-75">Attention</p>
              <p class="mt-2 text-base font-semibold">No active attention counters</p>
            </div>
          )}
        </section>

        <section class="grid min-w-0 gap-6 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Next Safe Action</p>
            <h3 class="mt-3 text-2xl font-semibold text-white" data-dashboard-next-label>{dashboardView.nextActionLabel}</h3>
            <p class="mt-3 leading-relaxed text-slate-300" data-dashboard-next-reason>{dashboardView.nextActionReason}</p>
            <code
              class="mt-4 block whitespace-pre-wrap break-all border border-slate-700 bg-[#050a12] px-4 py-3 font-mono text-[10px] leading-relaxed text-slate-200 sm:text-sm"
              data-dashboard-next-command
              hidden={!dashboardView.nextActionCommand}
            >
              {dashboardView.nextActionCommand}
            </code>
          </div>

          <div class="min-w-0 border border-slate-700 bg-[#111b27] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-400">Capacity</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-2" data-dashboard-capacity>
              {dashboardView.capacity.map((item) => (
                <div class="border border-slate-700 bg-slate-950/45 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">{formatLabel(item.label)}</p>
                  <p class="mt-2 font-mono text-2xl text-white">{item.value}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Project Portfolio</p>
              <h2 class="mt-2 text-2xl font-semibold text-white">Work queue by project</h2>
            </div>
            <a href={sitePath('/review/')} class="hidden text-sm font-semibold text-brand-200 hover:text-white sm:inline">Review detail</a>
          </div>
          <div class="mt-5 grid gap-4 lg:grid-cols-[0.85fr_1.15fr]" data-dashboard-project-portfolio>
            {dashboardView.projectDetails.length && selectedProjectDetail ? (
              <>
                <div class="space-y-2" data-dashboard-projects>
                  {dashboardView.projectDetails.map((project, index) => (
                    <button
                      type="button"
                      class={`w-full border px-4 py-3 text-left transition hover:border-brand-300/70 ${index === 0 ? 'border-brand-300/70 bg-brand-400/10' : 'border-slate-700 bg-slate-900/60'}`}
                      data-project-select
                      data-project-key={project.project_key}
                      aria-pressed={index === 0 ? 'true' : 'false'}
                    >
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="truncate font-semibold text-white">{project.display_name}</p>
                          <p class="mt-1 truncate font-mono text-xs text-slate-500">{project.project_key}</p>
                        </div>
                        <span class={`whitespace-nowrap border px-2 py-1 text-xs font-semibold ${severityClasses[project.severity]}`}>{severityLabels[project.severity]}</span>
                      </div>
                      <p class="mt-2 truncate text-xs text-slate-400">{project.status_line}</p>
                    </button>
                  ))}
                </div>
                <article class={`border p-5 ${severityClasses[selectedProjectDetail.severity]}`} data-dashboard-project-detail>
                  <div class="flex flex-wrap items-start justify-between gap-4">
                    <div class="min-w-0">
                      <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">{selectedProjectDetail.project_key}</p>
                      <h3 class="mt-2 text-xl font-semibold text-white">{selectedProjectDetail.display_name}</h3>
                      <p class="mt-2 text-sm leading-relaxed opacity-90">{selectedProjectDetail.primary_action}</p>
                    </div>
                    <span class="whitespace-nowrap font-mono text-xs opacity-75">{selectedProjectDetail.last_activity}</span>
                  </div>
                  <div class="mt-5 grid gap-3 sm:grid-cols-4">
                    <div class="border border-white/15 bg-slate-950/25 px-3 py-2">
                      <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">Plan</p>
                      <p class="mt-1 text-sm font-semibold">{selectedProjectDetail.plan}</p>
                    </div>
                    <div class="border border-white/15 bg-slate-950/25 px-3 py-2">
                      <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">Runtime</p>
                      <p class="mt-1 text-sm font-semibold">{selectedProjectDetail.runtime}</p>
                    </div>
                    <div class="border border-white/15 bg-slate-950/25 px-3 py-2">
                      <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">Closeout</p>
                      <p class="mt-1 text-sm font-semibold">{selectedProjectDetail.closeout}</p>
                    </div>
                    <div class="border border-white/15 bg-slate-950/25 px-3 py-2">
                      <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">Truth</p>
                      <p class="mt-1 text-sm font-semibold">{selectedProjectDetail.truth}</p>
                    </div>
                  </div>
                  <div class="mt-5 grid gap-3 text-sm sm:grid-cols-3">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">Decisions</p>
                      <p class="mt-1 font-mono text-lg text-white">{selectedProjectDetail.open_decision_count}</p>
                    </div>
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">Runtime Handoffs</p>
                      <p class="mt-1 font-mono text-lg text-white">{selectedProjectDetail.runtime_handoff_count}</p>
                    </div>
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">Truth Items</p>
                      <p class="mt-1 font-mono text-lg text-white">{selectedProjectDetail.truth_recovery_count}</p>
                    </div>
                  </div>
                  <div class="mt-5 space-y-2 text-sm opacity-90">
                    {selectedProjectDetail.decision_titles.map((title) => <p>Decision: {title}</p>)}
                    {selectedProjectDetail.runtime_stages.map((stage) => <p>Runtime: {stage}</p>)}
                    {selectedProjectDetail.truth_recovery_stages.map((stage) => <p>Truth: {stage}</p>)}
                  </div>
                </article>
              </>
            ) : (
              <div class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400">No project activity is currently visible.</div>
            )}
          </div>
        </section>
      </section>

      <aside class="min-w-0 space-y-6">
        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Health</p>
          <div class="mt-4 space-y-3" data-dashboard-health>
            {dashboardView.health.map((item) => (
              <article class={`border p-4 ${statusClasses(item.status)}`}>
                <div class="flex items-start justify-between gap-3">
                  <h3 class="font-semibold">{item.label}</h3>
                  <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">{item.status}</span>
                </div>
                <p class="mt-2 text-sm leading-relaxed opacity-85">{item.summary}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="decisions" class="min-w-0 border border-slate-700 bg-[#111827] p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Decision Inbox</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-400" data-dashboard-decision-summary>{dashboardView.decisionInbox.summary}</p>
            </div>
            <a href={sitePath('/decisions/')} class="whitespace-nowrap text-sm font-semibold text-brand-200 hover:text-white">Open</a>
          </div>
          <div class="mt-4 grid gap-3 text-xs sm:grid-cols-2" data-dashboard-decision-meta>
            <div class="border border-slate-700 bg-slate-950/50 p-3">
              <p class="uppercase tracking-[0.12em] text-slate-500">Open</p>
              <p class="mt-1 font-mono text-lg text-white">{dashboardView.decisionInbox.openCount}</p>
            </div>
            <div class="border border-slate-700 bg-slate-950/50 p-3">
              <p class="uppercase tracking-[0.12em] text-slate-500">Mode</p>
              <p class="mt-1 font-mono text-slate-200">{dashboardView.decisionInbox.actionMode}</p>
            </div>
          </div>
          <div class="mt-4 space-y-3" data-dashboard-decisions>
            {dashboardView.decisions.length ? (
              dashboardView.decisions.map((decision) => (
                <article class={`border p-4 ${severityClasses[decision.severity]}`}>
                  <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">{decision.project_key} · {formatLabel(decision.kind)}</p>
                  <h3 class="mt-2 text-base font-semibold text-white">{decision.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed opacity-90">{decision.what_changed}</p>
                  <p class="mt-2 text-sm leading-relaxed opacity-90">{decision.why_now}</p>
                  <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] opacity-75">Allowed</p>
                  <p class="mt-1 text-sm opacity-90">{decision.allowed_actions.join(' / ')}</p>
                  <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] opacity-75">Boundary</p>
                  <p class="mt-1 text-sm opacity-90">{decision.authorization_boundary}</p>
                </article>
              ))
            ) : (
              <article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
                <h3 class="font-semibold">No open decisions</h3>
                <p class="mt-2 text-sm leading-relaxed opacity-85">The current workstation surface does not report a human decision item.</p>
              </article>
            )}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Truth Recovery</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-400" data-dashboard-truth-summary>{dashboardView.acceptedTruthRecovery.summary}</p>
            </div>
            <a href={sitePath('/review/')} class="whitespace-nowrap text-sm font-semibold text-brand-200 hover:text-white">Review</a>
          </div>
          <div class="mt-4 space-y-3" data-dashboard-truth-recovery>
            {dashboardView.acceptedTruthRecovery.items.length ? (
              dashboardView.acceptedTruthRecovery.items.map((item) => (
                <article class={`border p-4 ${severityClasses[item.severity]}`}>
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="font-semibold text-white">{formatLabel(item.stage)}</h3>
                    <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">{item.acceptance_status}</span>
                  </div>
                  <p class="mt-2 break-all font-mono text-xs opacity-80">{item.project_key} · {item.closeout_id}</p>
                  <p class="mt-3 text-sm leading-relaxed opacity-90">{item.next_safe_action}</p>
                  {item.open_decision_kinds.length ? (
                    <p class="mt-2 text-xs font-semibold uppercase tracking-[0.12em] opacity-75">Open: {item.open_decision_kinds.join(' / ')}</p>
                  ) : null}
                  {item.resolve_command ? (
                    <code class="mt-3 block break-all border border-white/15 bg-slate-950/35 px-3 py-2 font-mono text-[11px] text-slate-100">{item.resolve_command}</code>
                  ) : null}
                  {item.retire_command ? (
                    <code class="mt-2 block break-all border border-white/15 bg-slate-950/35 px-3 py-2 font-mono text-[11px] text-slate-100">{item.retire_command}</code>
                  ) : null}
                  {item.action_envelopes.length ? (
                    <div class="mt-3 space-y-2">
                      {item.action_envelopes.map((action) => (
                        <div class="border border-white/15 bg-slate-950/30 px-3 py-2">
                          <div class="flex flex-wrap items-center justify-between gap-2">
                            <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-75">{formatLabel(action.action_kind)}</p>
                            <span class="font-mono text-[10px] opacity-70">{action.schema}</span>
                          </div>
                          <p class="mt-2 text-xs leading-relaxed opacity-85">{action.latest_receipt ? `Latest receipt: ${action.latest_receipt.result_status}` : action.expected_receipt_schema}</p>
                          <code class="mt-2 block break-all font-mono text-[10px] leading-relaxed text-slate-100">{action.allowed_command}</code>
                        </div>
                      ))}
                    </div>
                  ) : null}
                </article>
              ))
            ) : (
              <article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
                <h3 class="font-semibold">{dashboardView.acceptedTruthRecovery.emptyTitle}</h3>
                <p class="mt-2 text-sm leading-relaxed opacity-85">{dashboardView.acceptedTruthRecovery.emptySummary}</p>
              </article>
            )}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Scoped Graph</p>
          <h2 class="mt-2 text-xl font-semibold text-white" data-dashboard-graph-title>{selectedGraphTitle}</h2>
          <div class="mt-4 space-y-3" data-dashboard-graph>
            {selectedGraphEdges.map((edge) => (
              <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
                <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">{edge.from}</span>
                <span class="whitespace-nowrap text-xs uppercase tracking-[0.1em] text-brand-200">{edge.label}</span>
                <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">{edge.to}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-[#161423] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Assistant</p>
          <h2 class="mt-2 text-xl font-semibold text-white">Context helper</h2>
          <div data-dashboard-assistant>
            {selectedProjectDetail ? (
              <>
                <p class="mt-3 font-mono text-xs uppercase tracking-[0.12em] text-brand-200" data-dashboard-assistant-scope>
                  Scope: {selectedProjectDetail.display_name}
                </p>
                <p class="mt-3 text-sm leading-relaxed text-slate-300" data-dashboard-assistant-context>
                  {selectedProjectDetail.assistant_context}
                </p>
                <div class="mt-4 space-y-2" data-dashboard-assistant-refs>
                  {selectedProjectDetail.assistant_refs.map((ref) => (
                    <div class="border border-slate-700 bg-slate-950/35 px-3 py-2">
                      <div class="flex flex-wrap items-center justify-between gap-2">
                        <span class="text-xs font-semibold text-slate-100">{ref.label}</span>
                        <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-500">{formatLabel(ref.trust)}</span>
                      </div>
                      <p class="mt-1 break-all font-mono text-[10px] text-slate-400">{ref.reference}</p>
                    </div>
                  ))}
                </div>
                <div class="mt-4 flex flex-wrap gap-2" data-dashboard-assistant-prompts>
                  {selectedProjectDetail.assistant_prompts.map((prompt) => (
                    <button
                      class="border border-slate-600 px-3 py-2 text-xs font-semibold text-slate-200 hover:border-brand-300/70 hover:text-white"
                      type="button"
                      data-assistant-prompt={prompt.prompt}
                    >
                      {prompt.label}
                    </button>
                  ))}
                </div>
                <p class="mt-4 text-xs leading-relaxed text-slate-500" data-dashboard-assistant-boundary>
                  Read-only: answers must cite these refs or mark inference; execution still requires action envelopes and receipts.
                </p>
              </>
            ) : (
              <p class="mt-3 text-sm leading-relaxed text-slate-300" data-dashboard-assistant-context>
                No selected project is available. Review workstation health and decision inbox first.
              </p>
            )}
          </div>
        </section>
      </aside>
    </section>
  </main>

  <script id="dashboard-fallback-data" type="application/json" set:html={JSON.stringify(dashboardView)}></script>
  <script>
    import {
      dashboardViewFromSurface,
      formatLabel,
      severityClasses,
      severityLabels,
      statusClasses,
    } from '../lib/dashboardSurface';

    const app = document.getElementById('dashboard-app');
    const fallbackElement = document.getElementById('dashboard-fallback-data');
    const fallbackView = fallbackElement?.textContent ? JSON.parse(fallbackElement.textContent) : null;

    if (app && fallbackView) {
      fetchDashboardSurface(app, fallbackView);
    }

    async function fetchDashboardSurface(root, fallback) {
      const liveSurfaceUrl = root.dataset.liveSurfaceUrl;
      if (!liveSurfaceUrl) {
        renderDashboard(root, fallback);
        return;
      }

      try {
        const response = await fetch(liveSurfaceUrl, { cache: 'no-store' });
        if (!response.ok) {
          throw new Error(`workstation surface unavailable: ${response.status}`);
        }

        renderDashboard(root, dashboardViewFromSurface(await response.json()));
      } catch {
        renderDashboard(root, fallback);
      }
    }

    function renderDashboard(root, view) {
      setText(root, '[data-dashboard-source]', view.sourceLabel);
      setText(root, '[data-dashboard-profile]', view.profile);
      setText(root, '[data-dashboard-stale]', view.staleLabel);
      setText(root, '[data-dashboard-workstation]', view.workstationId);
      setText(root, '[data-dashboard-generated]', view.generatedAt);
      setText(root, '[data-dashboard-top-severity-label]', severityLabels[view.topSeverity]);
      setText(root, '[data-dashboard-top-title]', view.topTitle);
      setText(root, '[data-dashboard-top-summary]', view.topSummary);
      setText(root, '[data-dashboard-top-action]', view.topAction);
      setText(root, '[data-dashboard-next-label]', view.nextActionLabel);
      setText(root, '[data-dashboard-next-reason]', view.nextActionReason);
      setText(root, '[data-dashboard-decision-summary]', view.decisionInbox.summary);
      setText(root, '[data-dashboard-truth-summary]', view.acceptedTruthRecovery.summary);
      setSeverity(root, '[data-dashboard-top-severity]', view.topSeverity);
      setSeverity(root, '[data-dashboard-top-card]', view.topSeverity);
      setCommand(root, view.nextActionCommand);
      setHtml(root, '[data-dashboard-attention-counts]', attentionCountsHtml(view.attentionCounts));
      setHtml(root, '[data-dashboard-capacity]', view.capacity.map(capacityHtml).join(''));
      setHtml(root, '[data-dashboard-health]', view.health.map(healthHtml).join(''));
      setHtml(root, '[data-dashboard-project-portfolio]', projectPortfolioHtml(view.projectDetails));
      renderProjectGraph(root, view.projectDetails[0], view);
      renderProjectAssistant(root, view.projectDetails[0]);
      bindProjectPortfolio(root, view);
      setHtml(root, '[data-dashboard-decision-meta]', decisionMetaHtml(view.decisionInbox));
      setHtml(root, '[data-dashboard-decisions]', decisionsHtml(view.decisions));
      setHtml(root, '[data-dashboard-truth-recovery]', truthRecoveryHtml(view.acceptedTruthRecovery));
    }

    function setText(root, selector, value) {
      const element = root.querySelector(selector);
      if (element) {
        element.textContent = String(value ?? '');
      }
    }

    function setHtml(root, selector, value) {
      const element = root.querySelector(selector);
      if (element) {
        element.innerHTML = value;
      }
    }

    function setSeverity(root, selector, severity) {
      const element = root.querySelector(selector);
      if (!element) {
        return;
      }

      element.className = `${element.dataset.baseClass} ${severityClasses[severity]}`;
    }

    function setCommand(root, command) {
      const element = root.querySelector('[data-dashboard-next-command]');
      if (!element) {
        return;
      }

      element.textContent = command ?? '';
      element.toggleAttribute('hidden', !command);
    }

    function countHtml(item) {
      return `<div class="min-w-0 border border-slate-700 bg-slate-900/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">${escapeHtml(formatLabel(item.label))}</p>
        <p class="mt-3 font-mono text-3xl text-white">${escapeHtml(String(item.value))}</p>
      </div>`;
    }

    function attentionCountsHtml(items) {
      if (!items.length) {
        return `<div class="min-w-0 border border-emerald-400/35 bg-emerald-400/10 p-5 text-emerald-100 md:col-span-2 xl:col-span-3">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] opacity-75">Attention</p>
          <p class="mt-2 text-base font-semibold">No active attention counters</p>
        </div>`;
      }

      return items.map(countHtml).join('');
    }

    function capacityHtml(item) {
      return `<div class="border border-slate-700 bg-slate-950/45 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">${escapeHtml(formatLabel(item.label))}</p>
        <p class="mt-2 font-mono text-2xl text-white">${escapeHtml(String(item.value))}</p>
      </div>`;
    }

    function healthHtml(item) {
      return `<article class="border p-4 ${statusClasses(item.status)}">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-semibold">${escapeHtml(item.label)}</h3>
          <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">${escapeHtml(item.status)}</span>
        </div>
        <p class="mt-2 text-sm leading-relaxed opacity-85">${escapeHtml(item.summary)}</p>
      </article>`;
    }

    function projectPortfolioHtml(projects) {
      if (!projects.length) {
        return '<div class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400">No project activity is currently visible.</div>';
      }

      const selected = projects[0];
      return `<div class="space-y-2" data-dashboard-projects>
        ${projects.map((project, index) => projectSelectHtml(project, index === 0)).join('')}
      </div>
      ${projectDetailHtml(selected)}`;
    }

    function projectSelectHtml(project, selected) {
      return `<button
        type="button"
        class="${projectButtonClass(selected)}"
        data-project-select
        data-project-key="${escapeHtml(project.project_key)}"
        aria-pressed="${selected ? 'true' : 'false'}"
      >
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="truncate font-semibold text-white">${escapeHtml(project.display_name)}</p>
            <p class="mt-1 truncate font-mono text-xs text-slate-500">${escapeHtml(project.project_key)}</p>
          </div>
          <span class="whitespace-nowrap border px-2 py-1 text-xs font-semibold ${severityClasses[project.severity]}">${escapeHtml(severityLabels[project.severity])}</span>
        </div>
        <p class="mt-2 truncate text-xs text-slate-400">${escapeHtml(project.status_line)}</p>
      </button>`;
    }

    function projectButtonClass(selected) {
      return `w-full border px-4 py-3 text-left transition hover:border-brand-300/70 ${selected ? 'border-brand-300/70 bg-brand-400/10' : 'border-slate-700 bg-slate-900/60'}`;
    }

    function projectDetailHtml(project) {
      const detailLines = [
        ...project.decision_titles.map((title) => `Decision: ${title}`),
        ...project.runtime_stages.map((stage) => `Runtime: ${stage}`),
        ...project.truth_recovery_stages.map((stage) => `Truth: ${stage}`),
      ];
      return `<article class="border p-5 ${severityClasses[project.severity]}" data-dashboard-project-detail>
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="min-w-0">
            <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">${escapeHtml(project.project_key)}</p>
            <h3 class="mt-2 text-xl font-semibold text-white">${escapeHtml(project.display_name)}</h3>
            <p class="mt-2 text-sm leading-relaxed opacity-90">${escapeHtml(project.primary_action)}</p>
          </div>
          <span class="whitespace-nowrap font-mono text-xs opacity-75">${escapeHtml(project.last_activity)}</span>
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-4">
          ${projectMetricHtml('Plan', project.plan)}
          ${projectMetricHtml('Runtime', project.runtime)}
          ${projectMetricHtml('Closeout', project.closeout)}
          ${projectMetricHtml('Truth', project.truth)}
        </div>
        <div class="mt-5 grid gap-3 text-sm sm:grid-cols-3">
          ${projectCountHtml('Decisions', project.open_decision_count)}
          ${projectCountHtml('Runtime Handoffs', project.runtime_handoff_count)}
          ${projectCountHtml('Truth Items', project.truth_recovery_count)}
        </div>
        <div class="mt-5 space-y-2 text-sm opacity-90">
          ${detailLines.length ? detailLines.map((line) => `<p>${escapeHtml(line)}</p>`).join('') : '<p>No project-specific action is currently queued.</p>'}
        </div>
      </article>`;
    }

    function projectMetricHtml(label, value) {
      return `<div class="border border-white/15 bg-slate-950/25 px-3 py-2">
        <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">${escapeHtml(label)}</p>
        <p class="mt-1 text-sm font-semibold">${escapeHtml(value)}</p>
      </div>`;
    }

    function projectCountHtml(label, value) {
      return `<div>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">${escapeHtml(label)}</p>
        <p class="mt-1 font-mono text-lg text-white">${escapeHtml(String(value))}</p>
      </div>`;
    }

    function bindProjectPortfolio(root, view) {
      const container = root.querySelector('[data-dashboard-project-portfolio]');
      if (!container) {
        return;
      }

      container.querySelectorAll('[data-project-select]').forEach((button) => {
        button.addEventListener('click', () => {
          const project = view.projectDetails.find((item) => item.project_key === button.dataset.projectKey);
          if (!project) {
            return;
          }

          container.querySelectorAll('[data-project-select]').forEach((item) => {
            const selected = item === button;
            item.setAttribute('aria-pressed', selected ? 'true' : 'false');
            item.className = projectButtonClass(selected);
          });
          const detailTarget = root.querySelector('[data-dashboard-project-detail]');
          if (detailTarget) {
            detailTarget.outerHTML = projectDetailHtml(project);
          }
          renderProjectGraph(root, project, view);
          renderProjectAssistant(root, project);
        });
      });
    }

    function renderProjectGraph(root, project, fallbackView) {
      const title = project?.graph_title ?? fallbackView.graphTitle;
      const edges = project?.graph_edges?.length ? project.graph_edges : fallbackView.graphEdges;
      setText(root, '[data-dashboard-graph-title]', title);
      setHtml(root, '[data-dashboard-graph]', edges.map(edgeHtml).join(''));
    }

    function renderProjectAssistant(root, project) {
      setHtml(root, '[data-dashboard-assistant]', assistantPanelHtml(project));
    }

    function assistantPanelHtml(project) {
      if (!project) {
        return `<p class="mt-3 text-sm leading-relaxed text-slate-300" data-dashboard-assistant-context>
          No selected project is available. Review workstation health and decision inbox first.
        </p>`;
      }

      return `<p class="mt-3 font-mono text-xs uppercase tracking-[0.12em] text-brand-200" data-dashboard-assistant-scope>
          Scope: ${escapeHtml(project.display_name)}
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-300" data-dashboard-assistant-context>
          ${escapeHtml(project.assistant_context)}
        </p>
        <div class="mt-4 space-y-2" data-dashboard-assistant-refs>
          ${project.assistant_refs.map(assistantRefHtml).join('')}
        </div>
        <div class="mt-4 flex flex-wrap gap-2" data-dashboard-assistant-prompts>
          ${project.assistant_prompts.map(assistantPromptHtml).join('')}
        </div>
        <p class="mt-4 text-xs leading-relaxed text-slate-500" data-dashboard-assistant-boundary>
          Read-only: answers must cite these refs or mark inference; execution still requires action envelopes and receipts.
        </p>`;
    }

    function assistantRefHtml(ref) {
      return `<div class="border border-slate-700 bg-slate-950/35 px-3 py-2">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <span class="text-xs font-semibold text-slate-100">${escapeHtml(ref.label)}</span>
          <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-500">${escapeHtml(formatLabel(ref.trust))}</span>
        </div>
        <p class="mt-1 break-all font-mono text-[10px] text-slate-400">${escapeHtml(ref.reference)}</p>
      </div>`;
    }

    function assistantPromptHtml(prompt) {
      return `<button
        class="border border-slate-600 px-3 py-2 text-xs font-semibold text-slate-200 hover:border-brand-300/70 hover:text-white"
        type="button"
        data-assistant-prompt="${escapeHtml(prompt.prompt)}"
      >
        ${escapeHtml(prompt.label)}
      </button>`;
    }

    function decisionHtml(decision) {
      return `<article class="border p-4 ${severityClasses[decision.severity]}">
        <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">${escapeHtml(decision.project_key)} · ${escapeHtml(formatLabel(decision.kind))}</p>
        <h3 class="mt-2 text-base font-semibold text-white">${escapeHtml(decision.title)}</h3>
        <p class="mt-2 text-sm leading-relaxed opacity-90">${escapeHtml(decision.what_changed)}</p>
        <p class="mt-2 text-sm leading-relaxed opacity-90">${escapeHtml(decision.why_now)}</p>
        <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] opacity-75">Allowed</p>
        <p class="mt-1 text-sm opacity-90">${escapeHtml(decision.allowed_actions.join(' / '))}</p>
        <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] opacity-75">Boundary</p>
        <p class="mt-1 text-sm opacity-90">${escapeHtml(decision.authorization_boundary)}</p>
      </article>`;
    }

    function decisionMetaHtml(inbox) {
      return `<div class="border border-slate-700 bg-slate-950/50 p-3">
        <p class="uppercase tracking-[0.12em] text-slate-500">Open</p>
        <p class="mt-1 font-mono text-lg text-white">${escapeHtml(String(inbox.openCount))}</p>
      </div>
      <div class="border border-slate-700 bg-slate-950/50 p-3">
        <p class="uppercase tracking-[0.12em] text-slate-500">Mode</p>
        <p class="mt-1 font-mono text-slate-200">${escapeHtml(inbox.actionMode)}</p>
      </div>`;
    }

    function decisionsHtml(decisions) {
      if (!decisions.length) {
        return `<article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
          <h3 class="font-semibold">No open decisions</h3>
          <p class="mt-2 text-sm leading-relaxed opacity-85">The current workstation surface does not report a human decision item.</p>
        </article>`;
      }

      return decisions.map(decisionHtml).join('');
    }

    function truthRecoveryItemHtml(item) {
      const openKinds = item.open_decision_kinds.length
        ? `<p class="mt-2 text-xs font-semibold uppercase tracking-[0.12em] opacity-75">Open: ${escapeHtml(item.open_decision_kinds.join(' / '))}</p>`
        : '';
      const resolve = item.resolve_command
        ? `<code class="mt-3 block break-all border border-white/15 bg-slate-950/35 px-3 py-2 font-mono text-[11px] text-slate-100">${escapeHtml(item.resolve_command)}</code>`
        : '';
      const retire = item.retire_command
        ? `<code class="mt-2 block break-all border border-white/15 bg-slate-950/35 px-3 py-2 font-mono text-[11px] text-slate-100">${escapeHtml(item.retire_command)}</code>`
        : '';
      const actions = item.action_envelopes.length
        ? `<div class="mt-3 space-y-2">${item.action_envelopes.map(truthRecoveryActionHtml).join('')}</div>`
        : '';

      return `<article class="border p-4 ${severityClasses[item.severity]}">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-semibold text-white">${escapeHtml(formatLabel(item.stage))}</h3>
          <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">${escapeHtml(item.acceptance_status)}</span>
        </div>
        <p class="mt-2 break-all font-mono text-xs opacity-80">${escapeHtml(item.project_key)} · ${escapeHtml(item.closeout_id)}</p>
        <p class="mt-3 text-sm leading-relaxed opacity-90">${escapeHtml(item.next_safe_action)}</p>
        ${openKinds}
        ${resolve}
        ${retire}
        ${actions}
      </article>`;
    }

    function truthRecoveryActionHtml(action) {
      const receipt = action.latest_receipt
        ? `Latest receipt: ${escapeHtml(action.latest_receipt.result_status)}`
        : escapeHtml(action.expected_receipt_schema);
      return `<div class="border border-white/15 bg-slate-950/30 px-3 py-2">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-75">${escapeHtml(formatLabel(action.action_kind))}</p>
          <span class="font-mono text-[10px] opacity-70">${escapeHtml(action.schema)}</span>
        </div>
        <p class="mt-2 text-xs leading-relaxed opacity-85">${receipt}</p>
        <code class="mt-2 block break-all font-mono text-[10px] leading-relaxed text-slate-100">${escapeHtml(action.allowed_command)}</code>
      </div>`;
    }

    function truthRecoveryHtml(recovery) {
      if (!recovery.items.length) {
        return `<article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
          <h3 class="font-semibold">${escapeHtml(recovery.emptyTitle)}</h3>
          <p class="mt-2 text-sm leading-relaxed opacity-85">${escapeHtml(recovery.emptySummary)}</p>
        </article>`;
      }

      return recovery.items.map(truthRecoveryItemHtml).join('');
    }

    function edgeHtml(edge) {
      return `<div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
        <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">${escapeHtml(edge.from)}</span>
        <span class="whitespace-nowrap text-xs uppercase tracking-[0.1em] text-brand-200">${escapeHtml(edge.label)}</span>
        <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">${escapeHtml(edge.to)}</span>
      </div>`;
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, (char) => {
        switch (char) {
          case '&':
            return '&amp;';
          case '<':
            return '&lt;';
          case '>':
            return '&gt;';
          case '"':
            return '&quot;';
          case "'":
            return '&#39;';
          default:
            return char;
        }
      });
    }
  </script>

  <Footer />
</Base>
