---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AssistantReadout from '../components/AssistantReadout.astro';
import SourceStatus from '../components/SourceStatus.astro';
import { sitePath } from '../lib/paths';
import {
  dashboardViewFromSurface,
  dashboardAssistantActions,
  dashboardAssistantAnswer,
  dashboardAssistantPrompts,
  dashboardAssistantRefs,
  formatLabel,
  severityClasses,
  severityLabels,
  statusClasses,
  type DashboardView,
} from '../lib/dashboardSurface';

import workstationSurface from '../../../tests/fixtures/ui/workstation_surface/attention.json';

const dashboardView = dashboardViewFromSurface(workstationSurface) as DashboardView;
const dashboardAssistant = {
  answer: dashboardAssistantAnswer(dashboardView),
  prompts: dashboardAssistantPrompts(dashboardView),
  refs: dashboardAssistantRefs(dashboardView),
  actions: dashboardAssistantActions(dashboardView),
};
---

<Base
  title="Forager Dashboard"
  description="Read-only Forager workstation dashboard for projects, decisions, health, provenance, and accepted-truth state."
>
  <Nav />

  <main
    id="dashboard-app"
    class="min-h-screen bg-[#08111d] pt-24 text-slate-100"
    data-live-surface-url={sitePath('/workstation-surface.json')}
  >
    <section class="border-y border-slate-700/70 bg-[#101a27] px-6 py-5">
      <div class="mx-auto grid max-w-7xl gap-5 xl:grid-cols-[1fr_auto] xl:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-300">Forager Operations</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">Workstation command center</h1>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-400">
            Source: <span class="font-medium text-slate-200" data-dashboard-source>{dashboardView.sourceLabel}</span>
            <span class="text-slate-600"> / </span>
            Profile: <span class="font-mono text-slate-200" data-dashboard-profile>{dashboardView.profile}</span>
            <span class="text-slate-600"> / </span>
            Freshness: <span class="font-medium text-slate-200" data-dashboard-stale>{dashboardView.staleLabel}</span>
          </p>
        </div>

        <div class="grid gap-3 text-sm sm:grid-cols-3">
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Workstation</p>
            <p class="mt-1 font-mono text-slate-100" data-dashboard-workstation>{dashboardView.workstationId}</p>
          </div>
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Generated</p>
            <p class="mt-1 font-mono text-slate-100" data-dashboard-generated>{dashboardView.generatedAt}</p>
          </div>
          <div
            class={`border px-4 py-3 ${severityClasses[dashboardView.topSeverity]}`}
            data-dashboard-top-severity
            data-base-class="border px-4 py-3"
          >
            <p class="opacity-75">Top attention</p>
            <p class="mt-1 font-semibold" data-dashboard-top-severity-label>{severityLabels[dashboardView.topSeverity]}</p>
          </div>
        </div>
      </div>
    </section>
    <SourceStatus
      detail="Static fixture data is visible until workstation-surface.json is loaded from the local export."
      command="npm run export:workstation-surface"
    />

    <section class="mx-auto grid max-w-7xl gap-6 px-6 py-8 xl:grid-cols-[1.25fr_0.75fr]">
      <section class="min-w-0 space-y-6">
        <div
          class={`min-w-0 border p-6 ${severityClasses[dashboardView.topSeverity]}`}
          data-dashboard-top-card
          data-base-class="min-w-0 border p-6"
        >
          <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-start">
            <div class="min-w-0">
              <p class="text-sm font-semibold uppercase tracking-[0.14em] opacity-75">Now</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white" data-dashboard-top-title>{dashboardView.topTitle}</h2>
              <p class="mt-4 max-w-4xl text-base leading-relaxed text-slate-100" data-dashboard-top-summary>{dashboardView.topSummary}</p>
            </div>
            <div class="flex flex-wrap gap-3">
              <a
                href={sitePath('/decisions/')}
                class="inline-flex border border-white/20 bg-slate-950/35 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-950/55"
                data-dashboard-top-action
              >
                {dashboardView.topAction}
              </a>
              <a
                href={sitePath('/review/')}
                class="inline-flex border border-slate-500/60 bg-slate-900/70 px-4 py-2 text-sm font-semibold text-slate-100 hover:bg-slate-800"
              >
                Open review
              </a>
            </div>
          </div>
        </div>

        <section class="grid min-w-0 gap-4 md:grid-cols-2 xl:grid-cols-3" data-dashboard-attention-counts>
          {dashboardView.attentionCounts.length ? (
            dashboardView.attentionCounts.map((item) => (
              <div class="min-w-0 border border-slate-700 bg-slate-900/70 p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">{formatLabel(item.label)}</p>
                <p class="mt-3 font-mono text-3xl text-white">{item.value}</p>
              </div>
            ))
          ) : (
            <div class="min-w-0 border border-emerald-400/35 bg-emerald-400/10 p-5 text-emerald-100 md:col-span-2 xl:col-span-3">
              <p class="text-xs font-semibold uppercase tracking-[0.14em] opacity-75">Attention</p>
              <p class="mt-2 text-base font-semibold">No active attention counters</p>
            </div>
          )}
        </section>

        <section class="grid min-w-0 gap-6 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Next Safe Action</p>
            <h3 class="mt-3 text-2xl font-semibold text-white" data-dashboard-next-label>{dashboardView.nextActionLabel}</h3>
            <p class="mt-3 leading-relaxed text-slate-300" data-dashboard-next-reason>{dashboardView.nextActionReason}</p>
            <code
              class="mt-4 block whitespace-pre-wrap break-all border border-slate-700 bg-[#050a12] px-4 py-3 font-mono text-[10px] leading-relaxed text-slate-200 sm:text-sm"
              data-dashboard-next-command
              hidden={!dashboardView.nextActionCommand}
            >
              {dashboardView.nextActionCommand}
            </code>
          </div>

          <div class="min-w-0 border border-slate-700 bg-[#111b27] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-400">Capacity</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-2" data-dashboard-capacity>
              {dashboardView.capacity.map((item) => (
                <div class="border border-slate-700 bg-slate-950/45 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">{formatLabel(item.label)}</p>
                  <p class="mt-2 font-mono text-2xl text-white">{item.value}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

          <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Work Portfolio</p>
                <h2 class="mt-2 text-2xl font-semibold text-white">Project attention summary</h2>
              </div>
              <a href={sitePath('/work/')} class="text-sm font-semibold text-brand-200 hover:text-white">Open work</a>
            </div>
            <div class="mt-5 grid gap-3 md:grid-cols-3" data-dashboard-work-summary>
              {dashboardView.projectDetails.length ? (
                dashboardView.projectDetails.slice(0, 3).map((project) => (
                  <article class={`min-w-0 border p-4 ${severityClasses[project.severity]}`}>
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <h3 class="truncate font-semibold text-white">{project.display_name}</h3>
                      <p class="mt-1 truncate font-mono text-xs opacity-70">{project.project_key}</p>
                    </div>
                    <span class="whitespace-nowrap text-xs font-semibold uppercase tracking-[0.12em] opacity-75">{severityLabels[project.severity]}</span>
                  </div>
                    <p class="mt-3 text-sm leading-relaxed opacity-90">{project.primary_action}</p>
                    <div class="mt-3 grid grid-cols-3 gap-2 text-xs">
                      <div>
                        <p class="uppercase tracking-[0.1em] opacity-60">Dec</p>
                        <p class="mt-1 font-mono text-base text-white">{project.open_decision_count}</p>
                      </div>
                      <div>
                        <p class="uppercase tracking-[0.1em] opacity-60">Run</p>
                        <p class="mt-1 font-mono text-base text-white">{project.runtime_handoff_count}</p>
                      </div>
                    <div>
                      <p class="uppercase tracking-[0.1em] opacity-60">Truth</p>
                      <p class="mt-1 font-mono text-base text-white">{project.truth_recovery_count}</p>
                    </div>
                  </div>
                </article>
              ))
            ) : (
              <div class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400 md:col-span-3">No project activity is currently visible.</div>
            )}
          </div>
        </section>
      </section>

      <aside class="min-w-0 space-y-6">
        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Health</p>
          <div class="mt-4 space-y-3" data-dashboard-health>
            {dashboardView.health.map((item) => (
              <article class={`border p-4 ${statusClasses(item.status)}`}>
                <div class="flex items-start justify-between gap-3">
                  <h3 class="font-semibold">{item.label}</h3>
                  <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">{item.status}</span>
                </div>
                <p class="mt-2 text-sm leading-relaxed opacity-85">{item.summary}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-[#0b1421] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Assistant</p>
          <h2 class="mt-2 text-xl font-semibold text-white">State briefing</h2>
          <div data-dashboard-assistant>
            <AssistantReadout
              answer={dashboardAssistant.answer}
              refs={dashboardAssistant.refs}
              actions={dashboardAssistant.actions}
              prompts={dashboardAssistant.prompts}
              answerAttrs={['data-dashboard-assistant-context', 'data-dashboard-assistant-answer']}
              refsAttr="data-dashboard-assistant-refs"
              actionsAttr="data-dashboard-assistant-actions"
              promptsAttr="data-dashboard-assistant-prompts"
              copyPromptAttr="data-dashboard-assistant-copy-prompt"
              copyStatusAttr="data-dashboard-assistant-copy-status"
              copyAriaPrefix="Copy dashboard prompt"
              boundaryText="Read-only: this assistant entry prepares a cited prompt. It does not run shell commands or bypass action envelopes."
            />
          </div>
        </section>

        <section id="decisions" class="min-w-0 border border-slate-700 bg-[#111827] p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Decision Inbox</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-400" data-dashboard-decision-summary>{dashboardView.decisionInbox.summary}</p>
            </div>
            <a href={sitePath('/decisions/')} class="whitespace-nowrap text-sm font-semibold text-brand-200 hover:text-white">Open</a>
          </div>
          <div class="mt-4 grid gap-3 text-xs sm:grid-cols-2" data-dashboard-decision-meta>
            <div class="border border-slate-700 bg-slate-950/50 p-3">
              <p class="uppercase tracking-[0.12em] text-slate-500">Open</p>
              <p class="mt-1 font-mono text-lg text-white">{dashboardView.decisionInbox.openCount}</p>
            </div>
            <div class="border border-slate-700 bg-slate-950/50 p-3">
              <p class="uppercase tracking-[0.12em] text-slate-500">Mode</p>
              <p class="mt-1 font-mono text-slate-200">{dashboardView.decisionInbox.actionMode}</p>
            </div>
            </div>
            <div class="mt-4 space-y-3" data-dashboard-decisions>
              {dashboardView.decisions.length ? (
                dashboardView.decisions.map((decision) => (
                  <article class={`border p-4 ${severityClasses[decision.severity]}`}>
                    <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">{decision.project_key} · {formatLabel(decision.kind)}</p>
                    <h3 class="mt-2 text-base font-semibold text-white">{decision.title}</h3>
                    <p class="mt-2 text-sm leading-relaxed opacity-90">{decision.why_now}</p>
                  </article>
                ))
              ) : (
                <article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
                  <h3 class="font-semibold">No open decisions</h3>
                <p class="mt-2 text-sm leading-relaxed opacity-85">The current workstation surface does not report a human decision item.</p>
              </article>
            )}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Truth Recovery</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-400" data-dashboard-truth-summary>{dashboardView.acceptedTruthRecovery.summary}</p>
            </div>
            <a href={sitePath('/review/')} class="whitespace-nowrap text-sm font-semibold text-brand-200 hover:text-white">Review</a>
          </div>
          <div class="mt-4 space-y-3" data-dashboard-truth-recovery>
            {dashboardView.acceptedTruthRecovery.items.length ? (
              dashboardView.acceptedTruthRecovery.items.map((item) => (
                <article class={`border p-4 ${severityClasses[item.severity]}`}>
                  <div class="flex items-start justify-between gap-3">
                      <h3 class="font-semibold text-white">{formatLabel(item.stage)}</h3>
                      <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">{item.acceptance_status}</span>
                    </div>
                    <p class="mt-2 break-all font-mono text-xs opacity-80">{item.project_key} · {item.closeout_id}</p>
                    <p class="mt-3 text-sm leading-relaxed opacity-90">{item.next_safe_action}</p>
                  </article>
                ))
              ) : (
                <article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
                  <h3 class="font-semibold">{dashboardView.acceptedTruthRecovery.emptyTitle}</h3>
                  <p class="mt-2 text-sm leading-relaxed opacity-85">{dashboardView.acceptedTruthRecovery.emptySummary}</p>
                </article>
              )}
            </div>
          </section>
        </aside>
    </section>
  </main>

  <script id="dashboard-fallback-data" type="application/json" set:html={JSON.stringify(dashboardView)}></script>
  <script>
    import {
      dashboardViewFromSurface,
      dashboardAssistantActions,
      dashboardAssistantAnswer,
      dashboardAssistantPrompts,
      dashboardAssistantRefs,
      formatLabel,
      severityClasses,
      severityLabels,
      statusClasses,
    } from '../lib/dashboardSurface';
    import {
      sourceStatusClasses,
      sourceStatusLabels,
    } from '../lib/sourceStatus';
    import {
      assistantReadoutHtml,
      bindAssistantPromptCopies,
    } from '../lib/assistantReadout';

    const WORKSTATION_REFRESH_COMMAND = 'npm run export:workstation-surface';

    const app = document.getElementById('dashboard-app');
    const fallbackElement = document.getElementById('dashboard-fallback-data');
    const fallbackView = fallbackElement?.textContent ? JSON.parse(fallbackElement.textContent) : null;

    if (app && fallbackView) {
      fetchDashboardSurface(app, fallbackView);
    }

    async function fetchDashboardSurface(root, fallback) {
      const liveSurfaceUrl = root.dataset.liveSurfaceUrl;
      if (!liveSurfaceUrl) {
        renderDashboard(root, fallback);
        setSourceStatus(
          root,
          'missing_surface_url',
          'No live workstation-surface URL is configured; showing static fixture fallback.',
          WORKSTATION_REFRESH_COMMAND,
        );
        return;
      }

      try {
        const response = await fetch(liveSurfaceUrl, { cache: 'no-store' });
        if (!response.ok) {
          throw new Error(`workstation surface unavailable: ${response.status}`);
        }

        const view = dashboardViewFromSurface(await response.json());
        renderDashboard(root, view);
        setSourceStatus(
          root,
          view.staleLabel.toLowerCase().includes('fresh') ? 'live' : 'stale_live',
          `Loaded workstation_surface.v1 from ${liveSurfaceUrl}; freshness is ${view.staleLabel}.`,
          WORKSTATION_REFRESH_COMMAND,
        );
      } catch {
        renderDashboard(root, fallback);
        setSourceStatus(
          root,
          'live_fetch_failed',
          `Could not load ${liveSurfaceUrl}; showing static fixture fallback.`,
          WORKSTATION_REFRESH_COMMAND,
        );
      }
    }

    function renderDashboard(root, view) {
      setText(root, '[data-dashboard-source]', view.sourceLabel);
      setText(root, '[data-dashboard-profile]', view.profile);
      setText(root, '[data-dashboard-stale]', view.staleLabel);
      setText(root, '[data-dashboard-workstation]', view.workstationId);
      setText(root, '[data-dashboard-generated]', view.generatedAt);
      setText(root, '[data-dashboard-top-severity-label]', severityLabels[view.topSeverity]);
      setText(root, '[data-dashboard-top-title]', view.topTitle);
      setText(root, '[data-dashboard-top-summary]', view.topSummary);
      setText(root, '[data-dashboard-top-action]', view.topAction);
      setText(root, '[data-dashboard-next-label]', view.nextActionLabel);
      setText(root, '[data-dashboard-next-reason]', view.nextActionReason);
      setText(root, '[data-dashboard-decision-summary]', view.decisionInbox.summary);
      setText(root, '[data-dashboard-truth-summary]', view.acceptedTruthRecovery.summary);
        setSeverity(root, '[data-dashboard-top-severity]', view.topSeverity);
        setSeverity(root, '[data-dashboard-top-card]', view.topSeverity);
        setCommand(root, view.nextActionCommand);
        setHtml(root, '[data-dashboard-attention-counts]', attentionCountsHtml(view.attentionCounts));
        setHtml(root, '[data-dashboard-capacity]', view.capacity.map(capacityHtml).join(''));
        setHtml(root, '[data-dashboard-health]', view.health.map(healthHtml).join(''));
        setHtml(root, '[data-dashboard-work-summary]', workSummaryHtml(view.projectDetails));
        setHtml(root, '[data-dashboard-decision-meta]', decisionMetaHtml(view.decisionInbox));
        setHtml(root, '[data-dashboard-decisions]', decisionsHtml(view.decisions));
        setHtml(root, '[data-dashboard-assistant]', dashboardAssistantHtml(view));
        setHtml(root, '[data-dashboard-truth-recovery]', truthRecoveryHtml(view.acceptedTruthRecovery));
        bindDashboardAssistantPrompts(root);
    }

    function setText(root, selector, value) {
      const element = root.querySelector(selector);
      if (element) {
        element.textContent = String(value ?? '');
      }
    }

    function setHtml(root, selector, value) {
      const element = root.querySelector(selector);
      if (element) {
        element.innerHTML = value;
      }
    }

    function setSeverity(root, selector, severity) {
      const element = root.querySelector(selector);
      if (!element) {
        return;
      }

      element.className = `${element.dataset.baseClass} ${severityClasses[severity]}`;
    }

    function setCommand(root, command) {
      const element = root.querySelector('[data-dashboard-next-command]');
      if (!element) {
        return;
      }

      element.textContent = command ?? '';
      element.toggleAttribute('hidden', !command);
    }

    function setSourceStatus(root, status, detail, command) {
      const element = root.querySelector('[data-source-status]');
      if (!element) {
        return;
      }

      element.className = `${element.dataset.baseClass} ${sourceStatusClasses[status]}`;
      setText(root, '[data-source-status-label]', sourceStatusLabels[status]);
      setText(root, '[data-source-status-detail]', detail);
      const commandElement = root.querySelector('[data-source-status-command]');
      if (commandElement) {
        commandElement.textContent = command ?? '';
        commandElement.toggleAttribute('hidden', !command);
      }
    }

    function countHtml(item) {
      return `<div class="min-w-0 border border-slate-700 bg-slate-900/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">${escapeHtml(formatLabel(item.label))}</p>
        <p class="mt-3 font-mono text-3xl text-white">${escapeHtml(String(item.value))}</p>
      </div>`;
    }

    function attentionCountsHtml(items) {
      if (!items.length) {
        return `<div class="min-w-0 border border-emerald-400/35 bg-emerald-400/10 p-5 text-emerald-100 md:col-span-2 xl:col-span-3">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] opacity-75">Attention</p>
          <p class="mt-2 text-base font-semibold">No active attention counters</p>
        </div>`;
      }

      return items.map(countHtml).join('');
    }

    function capacityHtml(item) {
      return `<div class="border border-slate-700 bg-slate-950/45 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-400">${escapeHtml(formatLabel(item.label))}</p>
        <p class="mt-2 font-mono text-2xl text-white">${escapeHtml(String(item.value))}</p>
      </div>`;
    }

    function healthHtml(item) {
      return `<article class="border p-4 ${statusClasses(item.status)}">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-semibold">${escapeHtml(item.label)}</h3>
          <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">${escapeHtml(item.status)}</span>
        </div>
        <p class="mt-2 text-sm leading-relaxed opacity-85">${escapeHtml(item.summary)}</p>
      </article>`;
    }

      function workSummaryHtml(projects) {
        if (!projects.length) {
          return '<div class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400 md:col-span-3">No project activity is currently visible.</div>';
        }

        return projects.slice(0, 3).map(workSummaryCardHtml).join('');
      }

      function workSummaryCardHtml(project) {
        return `<article class="min-w-0 border p-4 ${severityClasses[project.severity]}">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <h3 class="truncate font-semibold text-white">${escapeHtml(project.display_name)}</h3>
              <p class="mt-1 truncate font-mono text-xs opacity-70">${escapeHtml(project.project_key)}</p>
            </div>
            <span class="whitespace-nowrap text-xs font-semibold uppercase tracking-[0.12em] opacity-75">${escapeHtml(severityLabels[project.severity])}</span>
          </div>
          <p class="mt-3 text-sm leading-relaxed opacity-90">${escapeHtml(project.primary_action)}</p>
          <div class="mt-3 grid grid-cols-3 gap-2 text-xs">
            ${projectCountHtml('Dec', project.open_decision_count)}
            ${projectCountHtml('Run', project.runtime_handoff_count)}
            ${projectCountHtml('Truth', project.truth_recovery_count)}
          </div>
        </article>`;
      }

      function projectCountHtml(label, value) {
        return `<div>
          <p class="uppercase tracking-[0.1em] opacity-60">${escapeHtml(label)}</p>
          <p class="mt-1 font-mono text-base text-white">${escapeHtml(String(value))}</p>
        </div>`;
      }

      function decisionHtml(decision) {
        return `<article class="border p-4 ${severityClasses[decision.severity]}">
          <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">${escapeHtml(decision.project_key)} · ${escapeHtml(formatLabel(decision.kind))}</p>
          <h3 class="mt-2 text-base font-semibold text-white">${escapeHtml(decision.title)}</h3>
          <p class="mt-2 text-sm leading-relaxed opacity-90">${escapeHtml(decision.why_now)}</p>
        </article>`;
      }

    function decisionMetaHtml(inbox) {
      return `<div class="border border-slate-700 bg-slate-950/50 p-3">
        <p class="uppercase tracking-[0.12em] text-slate-500">Open</p>
        <p class="mt-1 font-mono text-lg text-white">${escapeHtml(String(inbox.openCount))}</p>
      </div>
      <div class="border border-slate-700 bg-slate-950/50 p-3">
        <p class="uppercase tracking-[0.12em] text-slate-500">Mode</p>
        <p class="mt-1 font-mono text-slate-200">${escapeHtml(inbox.actionMode)}</p>
      </div>`;
    }

    function decisionsHtml(decisions) {
      if (!decisions.length) {
        return `<article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
          <h3 class="font-semibold">No open decisions</h3>
          <p class="mt-2 text-sm leading-relaxed opacity-85">The current workstation surface does not report a human decision item.</p>
        </article>`;
      }

        return decisions.map(decisionHtml).join('');
      }

      function truthRecoveryItemHtml(item) {
        return `<article class="border p-4 ${severityClasses[item.severity]}">
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-semibold text-white">${escapeHtml(formatLabel(item.stage))}</h3>
            <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">${escapeHtml(item.acceptance_status)}</span>
          </div>
          <p class="mt-2 break-all font-mono text-xs opacity-80">${escapeHtml(item.project_key)} · ${escapeHtml(item.closeout_id)}</p>
          <p class="mt-3 text-sm leading-relaxed opacity-90">${escapeHtml(item.next_safe_action)}</p>
        </article>`;
      }

      function truthRecoveryHtml(recovery) {
        if (!recovery.items.length) {
          return `<article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
            <h3 class="font-semibold">${escapeHtml(recovery.emptyTitle)}</h3>
            <p class="mt-2 text-sm leading-relaxed opacity-85">${escapeHtml(recovery.emptySummary)}</p>
          </article>`;
        }

        return recovery.items.map(truthRecoveryItemHtml).join('');
      }

      function dashboardAssistantHtml(view) {
        const answer = dashboardAssistantAnswer(view);
        const refs = dashboardAssistantRefs(view);
        const actions = dashboardAssistantActions(view);
        const prompts = dashboardAssistantPrompts(view);
        return assistantReadoutHtml({
          answer,
          refs,
          actions,
          prompts,
          answerAttrs: ['data-dashboard-assistant-context', 'data-dashboard-assistant-answer'],
          refsAttr: 'data-dashboard-assistant-refs',
          actionsAttr: 'data-dashboard-assistant-actions',
          promptsAttr: 'data-dashboard-assistant-prompts',
          copyPromptAttr: 'data-dashboard-assistant-copy-prompt',
          copyStatusAttr: 'data-dashboard-assistant-copy-status',
          copyAriaPrefix: 'Copy dashboard prompt',
          boundaryText: 'Read-only: this assistant entry prepares a cited prompt. It does not run shell commands or bypass action envelopes.',
        });
      }

      function bindDashboardAssistantPrompts(root) {
        bindAssistantPromptCopies(root, {
          copyPromptAttr: 'data-dashboard-assistant-copy-prompt',
          copyStatusAttr: 'data-dashboard-assistant-copy-status',
        });
      }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, (char) => {
        switch (char) {
          case '&':
            return '&amp;';
          case '<':
            return '&lt;';
          case '>':
            return '&gt;';
          case '"':
            return '&quot;';
          case "'":
            return '&#39;';
          default:
            return char;
        }
      });
    }
  </script>

  <Footer />
</Base>
