---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AssistantReadout from '../components/AssistantReadout.astro';
import SourceStatus from '../components/SourceStatus.astro';
import { sitePath } from '../lib/paths';
import {
  dashboardViewFromSurface,
  formatLabel,
  severityClasses,
  severityLabels,
  type DashboardView,
} from '../lib/dashboardSurface';

import workstationSurface from '../../../tests/fixtures/ui/workstation_surface/attention.json';

const workView = dashboardViewFromSurface(workstationSurface) as DashboardView;
const selectedProjectDetail = workView.projectDetails[0];
const selectedGraphTitle = selectedProjectDetail?.graph_title ?? workView.graphTitle;
const selectedGraphEdges = selectedProjectDetail?.graph_edges.length
  ? selectedProjectDetail.graph_edges
  : workView.graphEdges;
const runtimeHandoffCount = workView.projectDetails.reduce((sum, project) => sum + project.runtime_handoff_count, 0);
const truthItemCount = workView.projectDetails.reduce((sum, project) => sum + project.truth_recovery_count, 0);
const projectNeedsTaskReview = (project) =>
  project.task_items.some((item) =>
    item.requires_operator_review || ['failed', 'resume_pending', 'pending_approval'].includes(item.status)
  );
const projectNeedsTaskRecovery = (project) =>
  project.task_items.some((item) =>
    ['failed', 'resume_pending'].includes(item.status)
    || ['recovery_required', 'resume_review_required'].includes(item.next_safe_action_kind ?? '')
  );
const projectHasAcceptedTruth = (project) => project.truth === 'accepted' || project.closeout === 'accepted';
const projectHasStaleEvidence = (project) => {
  const taskStale = project.task_items.some((item) =>
    [item.status, item.summary, item.next_safe_action_kind ?? '', ...item.inspection_items.map((inspection) => inspection.value)]
      .some((value) => value.toLowerCase().includes('stale'))
  );
  const attentionStale = project.attention_items.some((item) =>
    [item.status, item.summary, item.boundary].some((value) => value.toLowerCase().includes('stale'))
  );
  return taskStale || attentionStale;
};
const workFilterOptions = [
  ['all', 'All', workView.projectDetails.length],
  ['attention', 'Attention', workView.projectDetails.filter((project) => project.attention_count > 0 || project.severity === 'attention').length],
  ['blocked', 'Blocked', workView.projectDetails.filter((project) => project.severity === 'blocked' || project.runtime.includes('blocked')).length],
  ['running', 'Running', workView.projectDetails.filter((project) => project.runtime.includes('running')).length],
  ['needs_review', 'Review', workView.projectDetails.filter(projectNeedsTaskReview).length],
  ['recovery', 'Recovery', workView.projectDetails.filter(projectNeedsTaskRecovery).length],
  ['accepted', 'Accepted', workView.projectDetails.filter(projectHasAcceptedTruth).length],
  ['stale', 'Stale', workView.projectDetails.filter(projectHasStaleEvidence).length],
  ['truth_gap', 'Truth gap', workView.projectDetails.filter((project) => project.truth.includes('missing') || project.truth_recovery_count > 0).length],
];
const taskInspectionToneClasses = {
  neutral: 'border-slate-700 bg-slate-950/35 text-slate-200',
  muted: 'border-slate-800 bg-slate-950/20 text-slate-400',
  attention: 'border-amber-300/45 bg-amber-300/10 text-amber-100',
  success: 'border-emerald-300/45 bg-emerald-300/10 text-emerald-100',
  danger: 'border-rose-300/45 bg-rose-300/10 text-rose-100',
};
---

<Base
  title="Forager Work"
  description="Forager project portfolio surface for project state, scoped provenance, decision blockers, runtime handoffs, and accepted-truth recovery."
>
  <Nav />

  <main
    id="work-app"
    class="min-h-screen bg-[#08111d] pt-24 text-slate-100"
    data-live-surface-url={sitePath('/workstation-surface.json')}
  >
    <section class="border-y border-slate-700/70 bg-[#101a27] px-6 py-5">
      <div class="mx-auto grid max-w-7xl gap-5 xl:grid-cols-[1fr_auto] xl:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-300">Forager Work</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">Project work portfolio</h1>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-400">
            Source: <span class="font-medium text-slate-200" data-work-source>{workView.sourceLabel}</span>
            <span class="text-slate-600"> / </span>
            Profile: <span class="font-mono text-slate-200" data-work-profile>{workView.profile}</span>
            <span class="text-slate-600"> / </span>
            Freshness: <span class="font-medium text-slate-200" data-work-stale>{workView.staleLabel}</span>
          </p>
        </div>

        <div class="grid gap-3 text-sm sm:grid-cols-4">
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Projects</p>
            <p class="mt-1 font-mono text-slate-100" data-work-project-count>{workView.projectDetails.length}</p>
          </div>
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Decisions</p>
            <p class="mt-1 font-mono text-slate-100" data-work-decision-count>{workView.decisionInbox.openCount}</p>
          </div>
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Runtime</p>
            <p class="mt-1 font-mono text-slate-100" data-work-runtime-count>{runtimeHandoffCount}</p>
          </div>
          <div class="border border-slate-700 bg-slate-950/55 px-4 py-3">
            <p class="text-slate-400">Truth</p>
            <p class="mt-1 font-mono text-slate-100" data-work-truth-count>{truthItemCount}</p>
          </div>
        </div>
      </div>
    </section>
    <SourceStatus
      detail="Static fixture data is visible until workstation-surface.json is loaded from the local export."
      command="npm run export:workstation-surface"
    />

    <section class="mx-auto grid max-w-7xl gap-6 px-6 py-8 xl:grid-cols-[1.25fr_0.75fr]">
      <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Project Portfolio</p>
            <h2 class="mt-2 text-2xl font-semibold text-white">Work queue by project</h2>
          </div>
          <a href={sitePath('/dashboard/')} class="text-sm font-semibold text-brand-200 hover:text-white">Dashboard</a>
        </div>
        <div class="mt-5 flex flex-wrap gap-2" data-work-project-filters role="group" aria-label="Filter projects">
          {workFilterOptions.map(([id, label, count]) => (
            <button
              type="button"
              class={`border px-3 py-2 text-xs font-semibold transition ${id === 'all' ? 'border-brand-300/70 bg-brand-400/10 text-white' : 'border-slate-700 bg-slate-950/35 text-slate-300 hover:border-brand-300/70 hover:text-white'}`}
              data-work-project-filter={id}
              aria-pressed={id === 'all' ? 'true' : 'false'}
            >
              {label} <span class="ml-1 font-mono text-[10px] opacity-75">{count}</span>
            </button>
          ))}
        </div>
        <p class="mt-3 text-xs leading-relaxed text-slate-500" data-work-filter-summary>
          Showing all {workView.projectDetails.length} projects from the current workstation surface.
        </p>
        <div class="mt-5 grid gap-4 xl:grid-cols-[minmax(16rem,0.8fr)_minmax(0,1.2fr)]" data-work-project-portfolio>
          {workView.projectDetails.length && selectedProjectDetail ? (
            <>
              <div class="space-y-2" data-work-projects>
                {workView.projectDetails.map((project, index) => (
                  <button
                    type="button"
                    class={`w-full border px-4 py-3 text-left transition hover:border-brand-300/70 ${index === 0 ? 'border-brand-300/70 bg-brand-400/10' : 'border-slate-700 bg-slate-900/60'}`}
                    data-work-project-select
                    data-project-key={project.project_key}
                    aria-pressed={index === 0 ? 'true' : 'false'}
                  >
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <p class="truncate font-semibold text-white">{project.display_name}</p>
                        <p class="mt-1 truncate font-mono text-xs text-slate-500">{project.project_key}</p>
                      </div>
                      <span class={`whitespace-nowrap border px-2 py-1 text-xs font-semibold ${severityClasses[project.severity]}`}>{severityLabels[project.severity]}</span>
                    </div>
                    <div class="mt-3 grid gap-1.5 text-[10px] sm:grid-cols-2">
                      {[
                        ['Plan', project.plan],
                        ['Runtime', project.runtime],
                        ['Closeout', project.closeout],
                        ['Truth', project.truth],
                      ].map(([label, value]) => (
                        <span class="min-w-0 border border-slate-700 bg-slate-950/35 px-2 py-1 uppercase tracking-[0.08em] text-slate-300">
                          {label} <strong class="normal-case tracking-normal text-slate-100">{formatLabel(value)}</strong>
                        </span>
                      ))}
                    </div>
                  </button>
                ))}
              </div>
              <article class={`border p-5 ${severityClasses[selectedProjectDetail.severity]}`} data-work-project-detail>
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div class="min-w-0">
                    <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">{selectedProjectDetail.project_key}</p>
                    <h3 class="mt-2 text-xl font-semibold text-white">{selectedProjectDetail.display_name}</h3>
                    <p class="mt-2 text-sm leading-relaxed opacity-90">{selectedProjectDetail.primary_action}</p>
                  </div>
                  <span class="whitespace-nowrap font-mono text-xs opacity-75">{selectedProjectDetail.last_activity}</span>
                </div>
                <div class="mt-5 grid gap-3 sm:grid-cols-2 2xl:grid-cols-4" data-work-project-state-chips>
                  {[
                    ['Plan', selectedProjectDetail.plan],
                    ['Runtime', selectedProjectDetail.runtime],
                    ['Closeout', selectedProjectDetail.closeout],
                    ['Truth', selectedProjectDetail.truth],
                  ].map(([label, value]) => (
                    <div class="min-w-0 border border-white/15 bg-slate-950/25 px-3 py-2">
                      <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">{label}</p>
                      <p class="mt-1 break-words text-sm font-semibold">{formatLabel(value)}</p>
                    </div>
                  ))}
                </div>
                <div class="mt-5 grid gap-3 text-sm sm:grid-cols-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">Decisions</p>
                    <p class="mt-1 font-mono text-lg text-white">{selectedProjectDetail.open_decision_count}</p>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">Runtime Handoffs</p>
                    <p class="mt-1 font-mono text-lg text-white">{selectedProjectDetail.runtime_handoff_count}</p>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">Truth Items</p>
                    <p class="mt-1 font-mono text-lg text-white">{selectedProjectDetail.truth_recovery_count}</p>
                  </div>
                </div>
                <section class="mt-5" data-work-attention-path>
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <h4 class="text-sm font-semibold uppercase tracking-[0.12em] text-white/80">Attention path</h4>
                    <span class="font-mono text-xs opacity-65">{selectedProjectDetail.attention_items.length} item(s)</span>
                  </div>
                  <div class="mt-3 space-y-3">
                    {selectedProjectDetail.attention_items.length ? (
                      selectedProjectDetail.attention_items.map((item) => (
                        <article class={`border border-white/15 bg-slate-950/25 p-3 ${severityClasses[item.severity]}`}>
                          <div class="flex flex-wrap items-start justify-between gap-3">
                            <div class="min-w-0">
                              <p class="font-mono text-[10px] uppercase tracking-[0.12em] opacity-65">{item.kind}</p>
                              <h5 class="mt-1 font-semibold text-white">{item.title}</h5>
                            </div>
                            <span class="whitespace-nowrap border border-white/15 px-2 py-1 font-mono text-[10px] uppercase tracking-[0.1em] opacity-75">
                              {formatLabel(item.status)}
                            </span>
                          </div>
                          <p class="mt-2 text-sm leading-relaxed opacity-90">{item.summary}</p>
                          <dl class="mt-3 space-y-1.5 text-[11px] opacity-75">
                            <div class="grid gap-1 sm:grid-cols-[5rem_1fr]">
                              <dt class="font-semibold uppercase tracking-[0.1em]">Ref</dt>
                              <dd class="min-w-0 break-all font-mono">{item.reference || 'state-ref unavailable'}</dd>
                            </div>
                            <div class="grid gap-1 sm:grid-cols-[5rem_1fr]">
                              <dt class="font-semibold uppercase tracking-[0.1em]">Fallback</dt>
                              <dd class="min-w-0 break-all font-mono">{item.command || 'no command exposed'}</dd>
                            </div>
                          </dl>
                          <p class="mt-2 text-xs leading-relaxed opacity-70">{item.boundary}</p>
                        </article>
                      ))
                    ) : (
                      <article class="border border-emerald-400/35 bg-emerald-400/10 p-3 text-emerald-100">
                        <h5 class="font-semibold">No project attention item</h5>
                        <p class="mt-1 text-sm opacity-85">This project has no scoped decision, runtime handoff, or accepted-truth recovery item in the current surface.</p>
                      </article>
                    )}
                  </div>
                </section>
                <details class="mt-5 border border-white/15 bg-slate-950/20 p-3" data-work-task-drawer>
                  <summary class="cursor-pointer text-sm font-semibold uppercase tracking-[0.12em] text-white/80">
                    Active task drawer <span class="ml-2 font-mono text-xs opacity-65">{selectedProjectDetail.task_items.length} item(s)</span>
                  </summary>
                  <div class="mt-3 divide-y divide-white/10">
                    {selectedProjectDetail.task_items.length ? (
                      selectedProjectDetail.task_items.map((item) => (
                        <article class="grid gap-3 py-3 text-sm md:grid-cols-[9rem_1fr]">
                          <div class="min-w-0">
                            <p class="font-mono text-[10px] uppercase tracking-[0.12em] opacity-65">{item.kind}</p>
                            <p class="mt-1 break-words font-semibold text-white">{formatLabel(item.status)}</p>
                            {item.task_id ? (
                              <p class="mt-1 break-all font-mono text-[10px] opacity-60">{item.task_id}</p>
                            ) : null}
                          </div>
                          <div class="min-w-0">
                            <h5 class="font-semibold text-white">{item.title}</h5>
                            <p class="mt-1 leading-relaxed opacity-85">{item.summary}</p>
                            {item.inspection_items.length ? (
                              <div class="mt-3 grid gap-2 sm:grid-cols-2">
                                {item.inspection_items.map((inspection) => (
                                  <div class={`min-w-0 border px-2.5 py-2 ${taskInspectionToneClasses[inspection.tone] ?? taskInspectionToneClasses.neutral}`}>
                                    <p class="text-[10px] font-semibold uppercase tracking-[0.1em] opacity-70">{inspection.label}</p>
                                    <p class="mt-1 break-words font-mono text-[11px] leading-snug">{inspection.value}</p>
                                  </div>
                                ))}
                              </div>
                            ) : null}
                            {item.receipt_links.length ? (
                              <div class="mt-3 space-y-2">
                                <p class="text-[10px] font-semibold uppercase tracking-[0.1em] opacity-70">Action records</p>
                                {item.receipt_links.map((receipt) => (
                                  <div class="min-w-0 border border-white/15 bg-slate-950/25 px-2.5 py-2">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                      <span class="font-mono text-[10px] uppercase tracking-[0.1em] opacity-70">{formatLabel(receipt.source)}</span>
                                      <span class="font-mono text-[10px] opacity-70">{formatLabel(receipt.result_status)}</span>
                                    </div>
                                    <p class="mt-1 break-all font-mono text-[11px] leading-snug">{receipt.record_id}</p>
                                    {receipt.summary ? (
                                      <p class="mt-1 text-xs leading-relaxed opacity-75">{receipt.summary}</p>
                                    ) : null}
                                  </div>
                                ))}
                              </div>
                            ) : null}
                            <div class="mt-2 grid gap-1 text-[11px] opacity-70 sm:grid-cols-[4.5rem_1fr]">
                              <span class="font-semibold uppercase tracking-[0.1em]">Ref</span>
                              <span class="min-w-0 break-all font-mono">{item.reference || 'state-ref unavailable'}</span>
                              <span class="font-semibold uppercase tracking-[0.1em]">Check</span>
                              <span class="min-w-0 break-all font-mono">{item.command || 'no command exposed'}</span>
                            </div>
                          </div>
                        </article>
                      ))
                    ) : (
                      <p class="py-3 text-sm leading-relaxed opacity-75">No active task row is exposed for this project in the current workstation surface.</p>
                    )}
                  </div>
                </details>
              </article>
            </>
          ) : (
            <div class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400">No project activity is currently visible.</div>
          )}
        </div>
      </section>

      <aside class="min-w-0 space-y-6">
        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Scoped Graph</p>
          <h2 class="mt-2 text-xl font-semibold text-white" data-work-graph-title>{selectedGraphTitle}</h2>
          <div class="mt-4 space-y-3" data-work-graph>
            {selectedGraphEdges.map((edge) => (
              <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
                <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">{edge.from}</span>
                <span class="whitespace-nowrap text-xs uppercase tracking-[0.1em] text-brand-200">{edge.label}</span>
                <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">{edge.to}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-[#161423] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Assistant</p>
          <h2 class="mt-2 text-xl font-semibold text-white">Context helper</h2>
          <div data-work-assistant>
            {selectedProjectDetail ? (
              <>
                <p class="mt-3 font-mono text-xs uppercase tracking-[0.12em] text-brand-200" data-work-assistant-scope>
                  Scope: {selectedProjectDetail.display_name}
                </p>
                <AssistantReadout
                  answer={selectedProjectDetail.assistant_answer}
                  refs={selectedProjectDetail.assistant_refs}
                  actions={selectedProjectDetail.assistant_suggested_actions}
                  prompts={selectedProjectDetail.assistant_prompts}
                  answerAttrs={['data-work-assistant-context', 'data-work-assistant-answer']}
                  refsAttr="data-work-assistant-refs"
                  actionsAttr="data-work-assistant-actions"
                  promptsAttr="data-work-assistant-prompts"
                  copyPromptAttr="data-work-assistant-copy-prompt"
                  copyStatusAttr="data-work-assistant-copy-status"
                  copyAriaPrefix="Copy prompt"
                  boundaryText="Read-only: answers must cite these refs or mark inference; execution still requires action envelopes and receipts."
                />
              </>
            ) : (
              <p class="mt-3 text-sm leading-relaxed text-slate-300" data-work-assistant-context data-work-assistant-answer>
                No selected project is available. Review workstation health and decision inbox first.
              </p>
            )}
          </div>
        </section>

        <section class="min-w-0 border border-slate-700 bg-slate-950/55 p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-brand-200">Truth Recovery</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-400" data-work-truth-summary>{workView.acceptedTruthRecovery.summary}</p>
            </div>
            <a href={sitePath('/review/')} class="whitespace-nowrap text-sm font-semibold text-brand-200 hover:text-white">Review</a>
          </div>
          <div class="mt-4 space-y-3" data-work-truth-recovery>
            {workView.acceptedTruthRecovery.items.length ? (
              workView.acceptedTruthRecovery.items.map((item) => (
                <article class={`border p-4 ${severityClasses[item.severity]}`}>
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="font-semibold text-white">{formatLabel(item.stage)}</h3>
                    <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">{item.acceptance_status}</span>
                  </div>
                  <p class="mt-2 break-all font-mono text-xs opacity-80">{item.project_key} · {item.closeout_id}</p>
                  <p class="mt-3 text-sm leading-relaxed opacity-90">{item.next_safe_action}</p>
                </article>
              ))
            ) : (
              <article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
                <h3 class="font-semibold">{workView.acceptedTruthRecovery.emptyTitle}</h3>
                <p class="mt-2 text-sm leading-relaxed opacity-85">{workView.acceptedTruthRecovery.emptySummary}</p>
              </article>
            )}
          </div>
        </section>
      </aside>
    </section>
  </main>

  <script id="work-fallback-data" type="application/json" set:html={JSON.stringify(workView)}></script>
  <script>
    import {
      dashboardViewFromSurface,
      formatLabel,
      severityClasses,
      severityLabels,
    } from '../lib/dashboardSurface';
    import {
      sourceStatusClasses,
      sourceStatusLabels,
    } from '../lib/sourceStatus';
    import {
      assistantReadoutHtml,
      bindAssistantPromptCopies,
    } from '../lib/assistantReadout';

    const WORKSTATION_REFRESH_COMMAND = 'npm run export:workstation-surface';
    const taskInspectionToneClasses = {
      neutral: 'border-slate-700 bg-slate-950/35 text-slate-200',
      muted: 'border-slate-800 bg-slate-950/20 text-slate-400',
      attention: 'border-amber-300/45 bg-amber-300/10 text-amber-100',
      success: 'border-emerald-300/45 bg-emerald-300/10 text-emerald-100',
      danger: 'border-rose-300/45 bg-rose-300/10 text-rose-100',
    };
    const app = document.getElementById('work-app');
    const fallbackElement = document.getElementById('work-fallback-data');
    const fallbackView = fallbackElement?.textContent ? JSON.parse(fallbackElement.textContent) : null;

    if (app && fallbackView) {
      fetchWorkSurface(app, fallbackView);
    }

    async function fetchWorkSurface(root, fallback) {
      const liveSurfaceUrl = root.dataset.liveSurfaceUrl;
      if (!liveSurfaceUrl) {
        renderWork(root, fallback);
        setSourceStatus(
          root,
          'missing_surface_url',
          'No live workstation-surface URL is configured; showing static fixture fallback.',
          WORKSTATION_REFRESH_COMMAND,
        );
        return;
      }

      try {
        const response = await fetch(liveSurfaceUrl, { cache: 'no-store' });
        if (!response.ok) {
          throw new Error(`workstation surface unavailable: ${response.status}`);
        }

        const view = dashboardViewFromSurface(await response.json());
        renderWork(root, view);
        setSourceStatus(
          root,
          view.staleLabel.toLowerCase().includes('fresh') ? 'live' : 'stale_live',
          `Loaded workstation_surface.v1 from ${liveSurfaceUrl}; freshness is ${view.staleLabel}.`,
          WORKSTATION_REFRESH_COMMAND,
        );
      } catch {
        renderWork(root, fallback);
        setSourceStatus(
          root,
          'live_fetch_failed',
          `Could not load ${liveSurfaceUrl}; showing static fixture fallback.`,
          WORKSTATION_REFRESH_COMMAND,
        );
      }
    }

    function renderWork(root, view) {
      setText(root, '[data-work-source]', view.sourceLabel);
      setText(root, '[data-work-profile]', view.profile);
      setText(root, '[data-work-stale]', view.staleLabel);
      setText(root, '[data-work-project-count]', view.projectDetails.length);
      setText(root, '[data-work-decision-count]', view.decisionInbox.openCount);
      setText(root, '[data-work-runtime-count]', sumProjectCount(view.projectDetails, 'runtime_handoff_count'));
      setText(root, '[data-work-truth-count]', sumProjectCount(view.projectDetails, 'truth_recovery_count'));
      setText(root, '[data-work-truth-summary]', view.acceptedTruthRecovery.summary);
      renderProjectSet(root, view, 'all');
      setHtml(root, '[data-work-truth-recovery]', truthRecoveryHtml(view.acceptedTruthRecovery));
    }

    function sumProjectCount(projects, field) {
      return projects.reduce((sum, project) => sum + Number(project[field] ?? 0), 0);
    }

    function setText(root, selector, value) {
      const element = root.querySelector(selector);
      if (element) {
        element.textContent = String(value ?? '');
      }
    }

    function setHtml(root, selector, value) {
      const element = root.querySelector(selector);
      if (element) {
        element.innerHTML = value;
      }
    }

    function setSourceStatus(root, status, detail, command) {
      const element = root.querySelector('[data-source-status]');
      if (!element) {
        return;
      }

      element.className = `${element.dataset.baseClass} ${sourceStatusClasses[status]}`;
      setText(root, '[data-source-status-label]', sourceStatusLabels[status]);
      setText(root, '[data-source-status-detail]', detail);
      const commandElement = root.querySelector('[data-source-status-command]');
      if (commandElement) {
        commandElement.textContent = command ?? '';
        commandElement.toggleAttribute('hidden', !command);
      }
    }

    function renderProjectSet(root, view, filterId) {
      const projects = filterProjects(view.projectDetails, filterId);
      const selected = projects[0];
      setHtml(root, '[data-work-project-filters]', projectFilterControlsHtml(view.projectDetails, filterId));
      setText(root, '[data-work-filter-summary]', projectFilterSummary(view.projectDetails, projects, filterId));
      setHtml(root, '[data-work-project-portfolio]', projectPortfolioHtml(projects, filterId));
      renderProjectGraph(root, selected, view);
      renderProjectAssistant(root, selected);
      bindProjectFilters(root, view);
      bindProjectPortfolio(root, view);
      bindAssistantPrompts(root);
    }

    function projectPortfolioHtml(projects, filterId) {
      if (!projects.length) {
        return `<div class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400" data-work-projects>
          No projects match the ${escapeHtml(projectFilterLabel(filterId).toLowerCase())} filter.
        </div>
        <article class="border border-slate-700 bg-slate-900/60 p-5 text-slate-400" data-work-project-detail>
          Select another filter to inspect a project.
        </article>`;
      }

      const selected = projects[0];
      return `<div class="space-y-2" data-work-projects>
        ${projects.map((project, index) => projectSelectHtml(project, index === 0)).join('')}
      </div>
      ${projectDetailHtml(selected)}`;
    }

    function projectFilterControlsHtml(projects, selectedFilter) {
      return projectFilterOptions(projects).map((option) => `<button
        type="button"
        class="${projectFilterButtonClass(option.id === selectedFilter)}"
        data-work-project-filter="${escapeHtml(option.id)}"
        aria-pressed="${option.id === selectedFilter ? 'true' : 'false'}"
      >
        ${escapeHtml(option.label)} <span class="ml-1 font-mono text-[10px] opacity-75">${escapeHtml(String(option.count))}</span>
      </button>`).join('');
    }

    function projectFilterOptions(projects) {
      return [
        {
          id: 'all',
          label: 'All',
          count: projects.length,
        },
        {
          id: 'attention',
          label: 'Attention',
          count: filterProjects(projects, 'attention').length,
        },
        {
          id: 'blocked',
          label: 'Blocked',
          count: filterProjects(projects, 'blocked').length,
        },
        {
          id: 'running',
          label: 'Running',
          count: filterProjects(projects, 'running').length,
        },
        {
          id: 'needs_review',
          label: 'Review',
          count: filterProjects(projects, 'needs_review').length,
        },
        {
          id: 'recovery',
          label: 'Recovery',
          count: filterProjects(projects, 'recovery').length,
        },
        {
          id: 'accepted',
          label: 'Accepted',
          count: filterProjects(projects, 'accepted').length,
        },
        {
          id: 'stale',
          label: 'Stale',
          count: filterProjects(projects, 'stale').length,
        },
        {
          id: 'truth_gap',
          label: 'Truth gap',
          count: filterProjects(projects, 'truth_gap').length,
        },
      ];
    }

    function projectFilterButtonClass(selected) {
      return `border px-3 py-2 text-xs font-semibold transition ${selected ? 'border-brand-300/70 bg-brand-400/10 text-white' : 'border-slate-700 bg-slate-950/35 text-slate-300 hover:border-brand-300/70 hover:text-white'}`;
    }

    function projectFilterSummary(allProjects, filteredProjects, filterId) {
      if (filterId === 'all') {
        return `Showing all ${allProjects.length} projects from the current workstation surface.`;
      }

      return `Showing ${filteredProjects.length} of ${allProjects.length} projects matching ${projectFilterLabel(filterId).toLowerCase()}.`;
    }

    function projectFilterLabel(filterId) {
      return projectFilterOptions([]).find((option) => option.id === filterId)?.label ?? 'All';
    }

    function filterProjects(projects, filterId) {
      switch (filterId) {
        case 'attention':
          return projects.filter((project) => Number(project.attention_count ?? 0) > 0 || project.severity === 'attention');
        case 'blocked':
          return projects.filter((project) => project.severity === 'blocked' || String(project.runtime ?? '').includes('blocked'));
        case 'running':
          return projects.filter((project) => String(project.runtime ?? '').includes('running'));
        case 'needs_review':
          return projects.filter(projectNeedsTaskReview);
        case 'recovery':
          return projects.filter(projectNeedsTaskRecovery);
        case 'accepted':
          return projects.filter(projectHasAcceptedTruth);
        case 'stale':
          return projects.filter(projectHasStaleEvidence);
        case 'truth_gap':
          return projects.filter((project) => String(project.truth ?? '').includes('missing') || Number(project.truth_recovery_count ?? 0) > 0);
        default:
          return projects;
      }
    }

    function projectNeedsTaskReview(project) {
      const items = project.task_items ?? [];
      return items.some((item) =>
        Boolean(item.requires_operator_review)
        || ['failed', 'resume_pending', 'pending_approval'].includes(String(item.status ?? ''))
      );
    }

    function projectNeedsTaskRecovery(project) {
      const items = project.task_items ?? [];
      return items.some((item) =>
        ['failed', 'resume_pending'].includes(String(item.status ?? ''))
        || ['recovery_required', 'resume_review_required'].includes(String(item.next_safe_action_kind ?? ''))
      );
    }

    function projectHasAcceptedTruth(project) {
      return project.truth === 'accepted' || project.closeout === 'accepted';
    }

    function projectHasStaleEvidence(project) {
      const tasks = project.task_items ?? [];
      const taskStale = tasks.some((item) =>
        [
          item.status,
          item.summary,
          item.next_safe_action_kind,
          ...(item.inspection_items ?? []).map((inspection) => inspection.value),
        ].some((value) => String(value ?? '').toLowerCase().includes('stale'))
      );
      const attention = project.attention_items ?? [];
      const attentionStale = attention.some((item) =>
        [item.status, item.summary, item.boundary].some((value) => String(value ?? '').toLowerCase().includes('stale'))
      );
      return taskStale || attentionStale;
    }

    function projectSelectHtml(project, selected) {
      return `<button
        type="button"
        class="${projectButtonClass(selected)}"
        data-work-project-select
        data-project-key="${escapeHtml(project.project_key)}"
        aria-pressed="${selected ? 'true' : 'false'}"
      >
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="truncate font-semibold text-white">${escapeHtml(project.display_name)}</p>
            <p class="mt-1 truncate font-mono text-xs text-slate-500">${escapeHtml(project.project_key)}</p>
          </div>
          <span class="whitespace-nowrap border px-2 py-1 text-xs font-semibold ${severityClasses[project.severity]}">${escapeHtml(severityLabels[project.severity])}</span>
        </div>
        ${projectSummaryChipsHtml(project)}
      </button>`;
    }

    function projectButtonClass(selected) {
      return `w-full border px-4 py-3 text-left transition hover:border-brand-300/70 ${selected ? 'border-brand-300/70 bg-brand-400/10' : 'border-slate-700 bg-slate-900/60'}`;
    }

    function projectDetailHtml(project) {
      return `<article class="border p-5 ${severityClasses[project.severity]}" data-work-project-detail>
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="min-w-0">
            <p class="font-mono text-xs uppercase tracking-[0.12em] opacity-75">${escapeHtml(project.project_key)}</p>
            <h3 class="mt-2 text-xl font-semibold text-white">${escapeHtml(project.display_name)}</h3>
            <p class="mt-2 text-sm leading-relaxed opacity-90">${escapeHtml(project.primary_action)}</p>
          </div>
          <span class="whitespace-nowrap font-mono text-xs opacity-75">${escapeHtml(project.last_activity)}</span>
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-2 2xl:grid-cols-4" data-work-project-state-chips>
          ${projectMetricHtml('Plan', project.plan)}
          ${projectMetricHtml('Runtime', project.runtime)}
          ${projectMetricHtml('Closeout', project.closeout)}
          ${projectMetricHtml('Truth', project.truth)}
        </div>
        <div class="mt-5 grid gap-3 text-sm sm:grid-cols-3">
          ${projectCountHtml('Decisions', project.open_decision_count)}
          ${projectCountHtml('Runtime Handoffs', project.runtime_handoff_count)}
          ${projectCountHtml('Truth Items', project.truth_recovery_count)}
        </div>
        ${projectAttentionPathHtml(project)}
        ${projectTaskDrawerHtml(project)}
      </article>`;
    }

    function projectMetricHtml(label, value) {
      return `<div class="min-w-0 border border-white/15 bg-slate-950/25 px-3 py-2">
        <p class="text-[10px] uppercase tracking-[0.12em] opacity-65">${escapeHtml(label)}</p>
        <p class="mt-1 break-words text-sm font-semibold">${escapeHtml(formatLabel(value))}</p>
      </div>`;
    }

    function projectSummaryChipsHtml(project) {
      const chips = [
        ['Plan', project.plan],
        ['Runtime', project.runtime],
        ['Closeout', project.closeout],
        ['Truth', project.truth],
      ];

      return `<div class="mt-3 grid gap-1.5 text-[10px] sm:grid-cols-2">
        ${chips.map(([label, value]) => `<span class="min-w-0 border border-slate-700 bg-slate-950/35 px-2 py-1 uppercase tracking-[0.08em] text-slate-300">
          ${escapeHtml(label)} <strong class="normal-case tracking-normal text-slate-100">${escapeHtml(formatLabel(value))}</strong>
        </span>`).join('')}
      </div>`;
    }

    function projectCountHtml(label, value) {
      return `<div>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] opacity-70">${escapeHtml(label)}</p>
        <p class="mt-1 font-mono text-lg text-white">${escapeHtml(String(value))}</p>
      </div>`;
    }

    function projectAttentionPathHtml(project) {
      const items = project.attention_items ?? [];
      const itemHtml = items.length
        ? items.map(projectAttentionItemHtml).join('')
        : `<article class="border border-emerald-400/35 bg-emerald-400/10 p-3 text-emerald-100">
          <h5 class="font-semibold">No project attention item</h5>
          <p class="mt-1 text-sm opacity-85">This project has no scoped decision, runtime handoff, or accepted-truth recovery item in the current surface.</p>
        </article>`;

      return `<section class="mt-5" data-work-attention-path>
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h4 class="text-sm font-semibold uppercase tracking-[0.12em] text-white/80">Attention path</h4>
          <span class="font-mono text-xs opacity-65">${escapeHtml(String(items.length))} item(s)</span>
        </div>
        <div class="mt-3 space-y-3">
          ${itemHtml}
        </div>
      </section>`;
    }

    function projectAttentionItemHtml(item) {
      return `<article class="border border-white/15 bg-slate-950/25 p-3 ${severityClasses[item.severity]}">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] opacity-65">${escapeHtml(item.kind)}</p>
            <h5 class="mt-1 font-semibold text-white">${escapeHtml(item.title)}</h5>
          </div>
          <span class="whitespace-nowrap border border-white/15 px-2 py-1 font-mono text-[10px] uppercase tracking-[0.1em] opacity-75">
            ${escapeHtml(formatLabel(item.status))}
          </span>
        </div>
        <p class="mt-2 text-sm leading-relaxed opacity-90">${escapeHtml(item.summary)}</p>
        <dl class="mt-3 space-y-1.5 text-[11px] opacity-75">
          <div class="grid gap-1 sm:grid-cols-[5rem_1fr]">
            <dt class="font-semibold uppercase tracking-[0.1em]">Ref</dt>
            <dd class="min-w-0 break-all font-mono">${escapeHtml(item.reference || 'state-ref unavailable')}</dd>
          </div>
          <div class="grid gap-1 sm:grid-cols-[5rem_1fr]">
            <dt class="font-semibold uppercase tracking-[0.1em]">Fallback</dt>
            <dd class="min-w-0 break-all font-mono">${escapeHtml(item.command || 'no command exposed')}</dd>
          </div>
        </dl>
        <p class="mt-2 text-xs leading-relaxed opacity-70">${escapeHtml(item.boundary)}</p>
      </article>`;
    }

    function projectTaskDrawerHtml(project) {
      const items = project.task_items ?? [];
      const itemHtml = items.length
        ? items.map(projectTaskItemHtml).join('')
        : '<p class="py-3 text-sm leading-relaxed opacity-75">No active task row is exposed for this project in the current workstation surface.</p>';

      return `<details class="mt-5 border border-white/15 bg-slate-950/20 p-3" data-work-task-drawer>
        <summary class="cursor-pointer text-sm font-semibold uppercase tracking-[0.12em] text-white/80">
          Active task drawer <span class="ml-2 font-mono text-xs opacity-65">${escapeHtml(String(items.length))} item(s)</span>
        </summary>
        <div class="mt-3 divide-y divide-white/10">
          ${itemHtml}
        </div>
      </details>`;
    }

    function projectTaskItemHtml(item) {
      const inspectionItems = item.inspection_items ?? [];
      const inspectionHtml = inspectionItems.length
        ? `<div class="mt-3 grid gap-2 sm:grid-cols-2">
            ${inspectionItems.map(projectTaskInspectionItemHtml).join('')}
          </div>`
        : '';
      const receiptLinks = item.receipt_links ?? [];
      const receiptHtml = receiptLinks.length
        ? `<div class="mt-3 space-y-2">
            <p class="text-[10px] font-semibold uppercase tracking-[0.1em] opacity-70">Action records</p>
            ${receiptLinks.map(projectTaskReceiptLinkHtml).join('')}
          </div>`
        : '';

      return `<article class="grid gap-3 py-3 text-sm md:grid-cols-[9rem_1fr]">
        <div class="min-w-0">
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] opacity-65">${escapeHtml(item.kind)}</p>
          <p class="mt-1 break-words font-semibold text-white">${escapeHtml(formatLabel(item.status))}</p>
          ${item.task_id ? `<p class="mt-1 break-all font-mono text-[10px] opacity-60">${escapeHtml(item.task_id)}</p>` : ''}
        </div>
        <div class="min-w-0">
          <h5 class="font-semibold text-white">${escapeHtml(item.title)}</h5>
          <p class="mt-1 leading-relaxed opacity-85">${escapeHtml(item.summary)}</p>
          ${inspectionHtml}
          ${receiptHtml}
          <div class="mt-2 grid gap-1 text-[11px] opacity-70 sm:grid-cols-[4.5rem_1fr]">
            <span class="font-semibold uppercase tracking-[0.1em]">Ref</span>
            <span class="min-w-0 break-all font-mono">${escapeHtml(item.reference || 'state-ref unavailable')}</span>
            <span class="font-semibold uppercase tracking-[0.1em]">Check</span>
            <span class="min-w-0 break-all font-mono">${escapeHtml(item.command || 'no command exposed')}</span>
          </div>
        </div>
      </article>`;
    }

    function projectTaskReceiptLinkHtml(receipt) {
      return `<div class="min-w-0 border border-white/15 bg-slate-950/25 px-2.5 py-2">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <span class="font-mono text-[10px] uppercase tracking-[0.1em] opacity-70">${escapeHtml(formatLabel(receipt.source))}</span>
          <span class="font-mono text-[10px] opacity-70">${escapeHtml(formatLabel(receipt.result_status))}</span>
        </div>
        <p class="mt-1 break-all font-mono text-[11px] leading-snug">${escapeHtml(receipt.record_id)}</p>
        ${receipt.summary ? `<p class="mt-1 text-xs leading-relaxed opacity-75">${escapeHtml(receipt.summary)}</p>` : ''}
      </div>`;
    }

    function projectTaskInspectionItemHtml(item) {
      const toneClass = taskInspectionToneClasses[item.tone] ?? taskInspectionToneClasses.neutral;
      return `<div class="min-w-0 border px-2.5 py-2 ${toneClass}">
        <p class="text-[10px] font-semibold uppercase tracking-[0.1em] opacity-70">${escapeHtml(item.label)}</p>
        <p class="mt-1 break-words font-mono text-[11px] leading-snug">${escapeHtml(item.value)}</p>
      </div>`;
    }

    function bindProjectPortfolio(root, view) {
      const container = root.querySelector('[data-work-project-portfolio]');
      if (!container) {
        return;
      }

      container.querySelectorAll('[data-work-project-select]').forEach((button) => {
        button.addEventListener('click', () => {
          const project = view.projectDetails.find((item) => item.project_key === button.dataset.projectKey);
          if (!project) {
            return;
          }

          container.querySelectorAll('[data-work-project-select]').forEach((item) => {
            const selected = item === button;
            item.setAttribute('aria-pressed', selected ? 'true' : 'false');
            item.className = projectButtonClass(selected);
          });
          const detailTarget = root.querySelector('[data-work-project-detail]');
          if (detailTarget) {
            detailTarget.outerHTML = projectDetailHtml(project);
          }
          renderProjectGraph(root, project, view);
          renderProjectAssistant(root, project);
          bindAssistantPrompts(root);
        });
      });
    }

    function bindProjectFilters(root, view) {
      root.querySelectorAll('[data-work-project-filter]').forEach((button) => {
        button.addEventListener('click', () => {
          renderProjectSet(root, view, button.dataset.workProjectFilter ?? 'all');
        });
      });
    }

    function renderProjectGraph(root, project, fallbackView) {
      const title = project?.graph_title ?? fallbackView.graphTitle;
      const edges = project?.graph_edges?.length ? project.graph_edges : fallbackView.graphEdges;
      setText(root, '[data-work-graph-title]', title);
      setHtml(root, '[data-work-graph]', edges.map(edgeHtml).join(''));
    }

    function renderProjectAssistant(root, project) {
      setHtml(root, '[data-work-assistant]', assistantPanelHtml(project));
    }

    function assistantPanelHtml(project) {
      if (!project) {
        return `<p class="mt-3 text-sm leading-relaxed text-slate-300" data-work-assistant-context data-work-assistant-answer>
          No selected project is available. Review workstation health and decision inbox first.
        </p>`;
      }

      return `<p class="mt-3 font-mono text-xs uppercase tracking-[0.12em] text-brand-200" data-work-assistant-scope>
          Scope: ${escapeHtml(project.display_name)}
        </p>
        ${assistantReadoutHtml({
          answer: project.assistant_answer || project.assistant_context,
          refs: project.assistant_refs,
          actions: project.assistant_suggested_actions,
          prompts: project.assistant_prompts,
          answerAttrs: ['data-work-assistant-context', 'data-work-assistant-answer'],
          refsAttr: 'data-work-assistant-refs',
          actionsAttr: 'data-work-assistant-actions',
          promptsAttr: 'data-work-assistant-prompts',
          copyPromptAttr: 'data-work-assistant-copy-prompt',
          copyStatusAttr: 'data-work-assistant-copy-status',
          copyAriaPrefix: 'Copy prompt',
          boundaryText: 'Read-only: answers must cite these refs or mark inference; execution still requires action envelopes and receipts.',
        })}`;
    }

    function bindAssistantPrompts(root) {
      bindAssistantPromptCopies(root, {
        copyPromptAttr: 'data-work-assistant-copy-prompt',
        copyStatusAttr: 'data-work-assistant-copy-status',
      });
    }

    function truthRecoveryItemHtml(item) {
      return `<article class="border p-4 ${severityClasses[item.severity]}">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-semibold text-white">${escapeHtml(formatLabel(item.stage))}</h3>
          <span class="whitespace-nowrap font-mono text-xs uppercase opacity-75">${escapeHtml(item.acceptance_status)}</span>
        </div>
        <p class="mt-2 break-all font-mono text-xs opacity-80">${escapeHtml(item.project_key)} · ${escapeHtml(item.closeout_id)}</p>
        <p class="mt-3 text-sm leading-relaxed opacity-90">${escapeHtml(item.next_safe_action)}</p>
      </article>`;
    }

    function truthRecoveryHtml(recovery) {
      if (!recovery.items.length) {
        return `<article class="border border-emerald-400/35 bg-emerald-400/10 p-4 text-emerald-100">
          <h3 class="font-semibold">${escapeHtml(recovery.emptyTitle)}</h3>
          <p class="mt-2 text-sm leading-relaxed opacity-85">${escapeHtml(recovery.emptySummary)}</p>
        </article>`;
      }

      return recovery.items.map(truthRecoveryItemHtml).join('');
    }

    function edgeHtml(edge) {
      return `<div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
        <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">${escapeHtml(edge.from)}</span>
        <span class="whitespace-nowrap text-xs uppercase tracking-[0.1em] text-brand-200">${escapeHtml(edge.label)}</span>
        <span class="truncate border border-slate-700 bg-slate-900/70 px-3 py-2 text-slate-100">${escapeHtml(edge.to)}</span>
      </div>`;
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, (char) => {
        switch (char) {
          case '&':
            return '&amp;';
          case '<':
            return '&lt;';
          case '>':
            return '&gt;';
          case '"':
            return '&quot;';
          case "'":
            return '&#39;';
          default:
            return char;
        }
      });
    }
  </script>

  <Footer />
</Base>
